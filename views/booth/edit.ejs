<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Booth - <%= booth.name %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="/css/animations.css">
</head>
<body class="bg-gradient-to-br from-blue-50 to-indigo-100 min-h-screen">
    <!-- Navigation -->
    <nav class="bg-white shadow-lg mb-8">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center py-4">
                <div class="flex items-center space-x-4">
                    <a href="/booth/dashboard" class="text-blue-600 hover:text-blue-800 transition-colors">
                        <svg class="w-6 h-6 inline-block mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
                        </svg>
                        Back to Dashboard
                    </a>
                    <span class="text-gray-300">|</span>
                    <a href="/booth/<%= booth._id %>/admin" class="text-blue-600 hover:text-blue-800 transition-colors">
                        Booth Admin
                    </a>
                </div>
                <div class="flex items-center space-x-4">
                    <span class="text-gray-700">Editing: <strong><%= booth.name %></strong></span>
                </div>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Page Header -->
        <div class="text-center mb-8">
            <h1 class="text-3xl font-bold text-gray-900 mb-2">Edit Booth</h1>
            <p class="text-gray-600">Update booth details and manage candidates</p>
        </div>

        <!-- Edit Form -->
        <form action="/booth/<%= booth._id %>/edit" method="POST" class="space-y-8">
            <!-- Booth Basic Info -->
            <div class="bg-white rounded-lg shadow-md p-6">
                <h2 class="text-xl font-semibold text-gray-800 mb-4 flex items-center">
                    <svg class="w-5 h-5 mr-2 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    Basic Information
                </h2>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label for="name" class="block text-sm font-medium text-gray-700 mb-2">Booth Name *</label>
                        <input type="text" id="name" name="name" value="<%= booth.name %>" 
                               class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500" 
                               required minlength="3" maxlength="100">
                    </div>
                    
                    <div>
                        <label for="maxMembers" class="block text-sm font-medium text-gray-700 mb-2">Max Members</label>
                        <input type="number" id="maxMembers" name="maxMembers" value="<%= booth.maxMembers %>" 
                               class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500" 
                               min="2" max="1000">
                    </div>
                </div>
                
                <div class="mt-4">
                    <label for="description" class="block text-sm font-medium text-gray-700 mb-2">Description</label>
                    <textarea id="description" name="description" rows="3" 
                              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500" 
                              maxlength="500"><%= booth.description %></textarea>
                </div>
            </div>

            <!-- Candidates Management -->
            <div class="bg-white rounded-lg shadow-md p-6">
                <h2 class="text-xl font-semibold text-gray-800 mb-4 flex items-center">
                    <svg class="w-5 h-5 mr-2 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
                    </svg>
                    Candidates Management
                </h2>
                
                <p class="text-sm text-gray-600 mb-4">
                    <strong>Note:</strong> Editing candidates will not affect existing votes. Current vote counts are preserved.
                </p>
                
                <div id="candidatesContainer" class="space-y-4">
                    <% booth.candidates.forEach((candidate, index) => { %>
                    <div class="candidate-row border border-gray-200 rounded-lg p-4 bg-gray-50">
                        <div class="flex items-start justify-between mb-3">
                            <h3 class="font-medium text-gray-800">Candidate #<%= index + 1 %></h3>
                            <% if (index > 1) { %>
                            <button type="button" onclick="removeCandidate(this)" 
                                    class="text-red-600 hover:text-red-800 transition-colors">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                                </svg>
                            </button>
                            <% } %>
                        </div>
                        
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1">Name *</label>
                                <input type="text" name="candidates[<%= index %>][name]" value="<%= candidate.name %>" 
                                       class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500" 
                                       required minlength="2" maxlength="100">
                            </div>
                            
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1">Description</label>
                                <input type="text" name="candidates[<%= index %>][description]" value="<%= candidate.description %>" 
                                       class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500" 
                                       maxlength="200">
                            </div>
                        </div>
                        
                        <div class="mt-3 text-sm text-gray-600">
                            Current votes: <span class="font-medium text-blue-600"><%= candidate.voteCount %></span>
                        </div>
                    </div>
                    <% }); %>
                </div>
                
                <button type="button" onclick="addCandidate()" 
                        class="mt-4 px-4 py-2 bg-green-600 text-white rounded-md hover:bg-green-700 transition-colors">
                    <svg class="w-4 h-4 inline-block mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
                    </svg>
                    Add Candidate
                </button>
            </div>

            <!-- Action Buttons -->
            <div class="bg-white rounded-lg shadow-md p-6">
                <div class="flex flex-col sm:flex-row justify-between items-center space-y-4 sm:space-y-0 sm:space-x-4">
                    <div class="text-sm text-gray-600">
                        Last updated: <%= new Date(booth.updatedAt).toLocaleString() %>
                    </div>
                    
                    <div class="flex space-x-3">
                        <a href="/booth/<%= booth._id %>/admin" 
                           class="px-6 py-2 bg-gray-500 text-white rounded-md hover:bg-gray-600 transition-colors">
                            Cancel
                        </a>
                        
                        <button type="submit" 
                                class="px-6 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 transition-colors">
                            <svg class="w-4 h-4 inline-block mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                            </svg>
                            Save Changes
                        </button>
                    </div>
                </div>
            </div>
        </form>
    </div>

    <!-- JavaScript -->
    <script>
        let candidateCount = <%- booth.candidates.length %>;

        function addCandidate() {
            const container = document.getElementById('candidatesContainer');
            const candidateHtml = `
                <div class="candidate-row border border-gray-200 rounded-lg p-4 bg-gray-50">
                    <div class="flex items-start justify-between mb-3">
                        <h3 class="font-medium text-gray-800">Candidate #${candidateCount + 1}</h3>
                        <button type="button" onclick="removeCandidate(this)" 
                                class="text-red-600 hover:text-red-800 transition-colors">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                            </svg>
                        </button>
                    </div>
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Name *</label>
                            <input type="text" name="candidates[${candidateCount}][name]" 
                                   class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500" 
                                   required minlength="2" maxlength="100">
                        </div>
                        
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Description</label>
                            <input type="text" name="candidates[${candidateCount}][description]" 
                                   class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500" 
                                   maxlength="200">
                        </div>
                    </div>
                    
                    <div class="mt-3 text-sm text-gray-600">
                        Current votes: <span class="font-medium text-blue-600">0</span>
                    </div>
                </div>
            `;
            
            container.insertAdjacentHTML('beforeend', candidateHtml);
            candidateCount++;
        }

        function removeCandidate(button) {
            const candidateRow = button.closest('.candidate-row');
            candidateRow.remove();
            
            // Renumber remaining candidates
            const candidates = document.querySelectorAll('.candidate-row');
            candidates.forEach((candidate, index) => {
                const header = candidate.querySelector('h3');
                header.textContent = `Candidate #${index + 1}`;
                
                // Update input names
                const nameInput = candidate.querySelector('input[name*="[name]"]');
                const descInput = candidate.querySelector('input[name*="[description]"]');
                
                nameInput.name = `candidates[${index}][name]`;
                descInput.name = `candidates[${index}][description]`;
            });
            
            candidateCount = candidates.length;
        }

        // Form validation
        document.querySelector('form').addEventListener('submit', function(e) {
            const candidates = document.querySelectorAll('input[name*="[name]"]');
            
            if (candidates.length < 2) {
                e.preventDefault();
                alert('At least 2 candidates are required.');
                return;
            }
            
            // Check for duplicate candidate names
            const names = Array.from(candidates).map(input => input.value.trim().toLowerCase());
            const uniqueNames = new Set(names);
            
            if (names.length !== uniqueNames.size) {
                e.preventDefault();
                alert('Candidate names must be unique.');
                return;
            }
        });
    </script>
</body>
</html>
