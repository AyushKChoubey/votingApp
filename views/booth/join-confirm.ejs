<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Confirm Join - <%= booth.name %> | VoteBooth</title>
    <link href="/public/css/tailwind.css" rel="stylesheet">
    
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="/public/css/animations.css" rel="stylesheet">
</head>
<body class="bg-gradient-to-br from-emerald-50 via-blue-50 to-teal-50 min-h-screen font-sans flex items-center justify-center py-12">
    <div class="max-w-lg w-full mx-4">
        <!-- Header -->
        <div class="text-center mb-8">
            <a href="/" class="inline-flex items-center mb-6 group">
                <i class="fas fa-vote-yea text-4xl text-primary mr-3 group-hover:scale-110 transition-transform"></i>
                <span class="font-bold text-3xl text-slate-800">VoteBooth</span>
            </a>
            <div class="mb-6">
                <div class="mx-auto w-20 h-20 bg-gradient-to-r from-emerald-500 to-teal-500 rounded-full flex items-center justify-center mb-4 animate-pulse">
                    <i class="fas fa-user-plus text-3xl text-white"></i>
                </div>
                <h2 class="text-2xl font-bold text-slate-900 mb-2">Join Booth Confirmation</h2>
                <p class="text-slate-600">Review booth details before joining</p>
            </div>
        </div>

        <!-- Error Message -->
        <% if (error) { %>
            <div class="mb-6 bg-red-50 border border-red-200 rounded-xl p-4 animate-slide-down">
                <div class="flex items-center">
                    <div class="flex-shrink-0">
                        <i class="fas fa-exclamation-circle text-red-500 text-xl"></i>
                    </div>
                    <div class="ml-3">
                        <p class="text-red-800 font-medium"><%= error %></p>
                    </div>
                </div>
            </div>
        <% } %>

        <!-- Booth Information Card -->
        <div class="bg-white rounded-2xl shadow-xl border border-slate-200 overflow-hidden mb-6">
            <!-- Header -->
            <div class="px-8 py-6 bg-gradient-to-r from-emerald-50 to-teal-50 border-b border-slate-200">
                <div class="flex items-center space-x-4">
                    <div class="w-16 h-16 bg-gradient-to-r from-emerald-500 to-teal-500 rounded-full flex items-center justify-center text-white font-bold text-xl">
                        <%= booth.name.charAt(0).toUpperCase() %>
                    </div>
                    <div class="flex-1">
                        <h3 class="text-xl font-bold text-slate-900"><%= booth.name %></h3>
                        <p class="text-sm text-slate-600">Created by <%= booth.creator.name %></p>
                        <div class="flex items-center mt-1">
                            <span class="px-2 py-1 text-xs font-medium rounded-full <%= booth.status === 'active' ? 'bg-emerald-100 text-emerald-800' : booth.status === 'draft' ? 'bg-gray-100 text-gray-700' : booth.status === 'paused' ? 'bg-amber-100 text-amber-800' : 'bg-red-100 text-red-800' %>">
                                <%= booth.status.charAt(0).toUpperCase() + booth.status.slice(1) %>
                            </span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Body -->
            <div class="p-8">
                <div class="mb-6">
                    <h4 class="text-sm font-semibold text-slate-700 mb-2">
                        <i class="fas fa-align-left text-slate-500 mr-2"></i>Description
                    </h4>
                    <p class="text-slate-600 bg-slate-50 rounded-lg p-4"><%= booth.description %></p>
                </div>

                <div class="grid grid-cols-2 gap-6 mb-6">
                    <div class="text-center">
                        <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center mx-auto mb-2">
                            <i class="fas fa-users text-blue-600 text-xl"></i>
                        </div>
                        <p class="text-sm font-medium text-slate-700">Members</p>
                        <p class="text-lg font-bold text-slate-900"><%= memberCount %></p>
                    </div>
                    <div class="text-center">
                        <div class="w-12 h-12 bg-purple-100 rounded-full flex items-center justify-center mx-auto mb-2">
                            <i class="fas fa-candidates-vote text-purple-600 text-xl"></i>
                        </div>
                        <p class="text-sm font-medium text-slate-700">Candidates</p>
                        <p class="text-lg font-bold text-slate-900"><%= booth.candidates.length %></p>
                    </div>
                </div>

                <!-- Candidates Preview -->
                <div class="mb-6">
                    <h4 class="text-sm font-semibold text-slate-700 mb-3">
                        <i class="fas fa-list text-slate-500 mr-2"></i>Voting Options
                    </h4>
                    <div class="space-y-2">
                        <% booth.candidates.slice(0, 4).forEach((candidate, index) => { %>
                        <div class="flex items-center space-x-3 p-3 bg-slate-50 rounded-lg">
                            <div class="w-8 h-8 bg-gradient-to-r from-blue-500 to-purple-600 rounded-full flex items-center justify-center text-white font-medium text-sm">
                                <%= candidate.name.charAt(0).toUpperCase() %>
                            </div>
                            <span class="font-medium text-slate-700"><%= candidate.name %></span>
                        </div>
                        <% }) %>
                        <% if (booth.candidates.length > 4) { %>
                        <div class="text-center py-2 text-sm text-slate-500">
                            + <%= booth.candidates.length - 4 %> more candidates
                        </div>
                        <% } %>
                    </div>
                </div>

                <!-- Booth Settings Info -->
                <div class="bg-slate-50 rounded-lg p-4 mb-6">
                    <h4 class="text-sm font-semibold text-slate-700 mb-3">
                        <i class="fas fa-cog text-slate-500 mr-2"></i>Booth Settings
                    </h4>
                    <div class="grid grid-cols-2 gap-4 text-xs">
                        <div class="flex items-center space-x-2">
                            <i class="fas <%= booth.settings.anonymousVoting ? 'fa-check-circle text-emerald-500' : 'fa-times-circle text-red-500' %>"></i>
                            <span class="text-slate-600">Anonymous Voting</span>
                        </div>
                        <div class="flex items-center space-x-2">
                            <i class="fas <%= booth.settings.allowMultipleVotes ? 'fa-check-circle text-emerald-500' : 'fa-times-circle text-red-500' %>"></i>
                            <span class="text-slate-600">Vote Changes</span>
                        </div>
                        <div class="flex items-center space-x-2">
                            <i class="fas <%= booth.settings.resultsVisibleToVoters ? 'fa-check-circle text-emerald-500' : 'fa-times-circle text-red-500' %>"></i>
                            <span class="text-slate-600">Results Visible</span>
                        </div>
                        <div class="flex items-center space-x-2">
                            <i class="fas <%= booth.settings.requireApproval ? 'fa-check-circle text-amber-500' : 'fa-times-circle text-slate-400' %>"></i>
                            <span class="text-slate-600">Requires Approval</span>
                        </div>
                    </div>
                </div>

                <!-- Voting Status -->
                <div class="text-center mb-6">
                    <% if (booth.status === 'active') { %>
                        <div class="inline-flex items-center space-x-2 text-emerald-700 bg-emerald-100 px-4 py-2 rounded-full">
                            <i class="fas fa-play-circle"></i>
                            <span class="font-semibold">Voting is Active</span>
                        </div>
                        <p class="text-sm text-slate-600 mt-2">You can start voting immediately after joining</p>
                    <% } else if (booth.status === 'draft') { %>
                        <div class="inline-flex items-center space-x-2 text-gray-700 bg-gray-100 px-4 py-2 rounded-full">
                            <i class="fas fa-pause-circle"></i>
                            <span class="font-semibold">Voting Not Started</span>
                        </div>
                        <p class="text-sm text-slate-600 mt-2">You can join now and vote when the creator starts the booth</p>
                    <% } else if (booth.status === 'paused') { %>
                        <div class="inline-flex items-center space-x-2 text-amber-700 bg-amber-100 px-4 py-2 rounded-full">
                            <i class="fas fa-pause-circle"></i>
                            <span class="font-semibold">Voting Paused</span>
                        </div>
                        <p class="text-sm text-slate-600 mt-2">Voting is temporarily paused by the creator</p>
                    <% } else { %>
                        <div class="inline-flex items-center space-x-2 text-red-700 bg-red-100 px-4 py-2 rounded-full">
                            <i class="fas fa-stop-circle"></i>
                            <span class="font-semibold">Voting Ended</span>
                        </div>
                        <p class="text-sm text-slate-600 mt-2">This booth has closed, but you can still join to view results</p>
                    <% } %>
                </div>
            </div>
        </div>

        <!-- Action Buttons -->
        <div class="space-y-4">
            <form method="POST" action="/booth/<%= code %>/join-confirm" id="joinForm">
                <button type="submit" 
                        class="w-full bg-gradient-to-r from-emerald-600 to-teal-600 text-white px-8 py-4 rounded-xl font-semibold text-lg hover:from-emerald-700 hover:to-teal-700 transition-all duration-200 shadow-lg hover:shadow-xl transform hover:-translate-y-0.5">
                    <i class="fas fa-user-plus mr-3"></i>
                    <span id="joinButtonText">Join This Booth</span>
                </button>
            </form>

            <div class="grid grid-cols-2 gap-4">
                <a href="/booth/join" 
                   class="bg-white text-slate-700 border-2 border-slate-300 px-6 py-3 rounded-xl font-semibold text-center hover:bg-slate-50 transition-colors">
                    <i class="fas fa-arrow-left mr-2"></i>Back
                </a>
                <a href="/booth/dashboard" 
                   class="bg-slate-600 text-white px-6 py-3 rounded-xl font-semibold text-center hover:bg-slate-700 transition-colors">
                    <i class="fas fa-dashboard mr-2"></i>Dashboard
                </a>
            </div>
        </div>

        <!-- Info Box -->
        <div class="mt-8 bg-white/70 backdrop-blur-sm rounded-xl p-6 border border-slate-200">
            <div class="flex items-start space-x-3">
                <div class="flex-shrink-0">
                    <i class="fas fa-info-circle text-blue-500 text-xl"></i>
                </div>
                <div>
                    <h4 class="font-semibold text-slate-900 mb-2">What happens next?</h4>
                    <ul class="text-sm text-slate-600 space-y-1">
                        <li>• You'll become a member of this booth</li>
                        <li>• You can participate in voting (when active)</li>
                        <li>• You'll receive notifications about booth updates</li>
                        <% if (booth.settings.resultsVisibleToVoters) { %>
                        <li>• You can view real-time results</li>
                        <% } %>
                    </ul>
                </div>
            </div>
        </div>

        <!-- Footer -->
        <div class="mt-8 text-center text-xs text-slate-500">
            <p>
                By joining this booth, you agree to our 
                <a href="/terms" class="text-emerald-600 hover:text-emerald-700">Terms of Service</a>
            </p>
        </div>
    </div>

    <script>
        // Handle form submission
        document.getElementById('joinForm').addEventListener('submit', function() {
            const button = this.querySelector('button[type="submit"]');
            const buttonText = document.getElementById('joinButtonText');
            
            button.disabled = true;
            buttonText.innerHTML = '<i class="fas fa-spinner fa-spin mr-3"></i>Joining...';
            
            // Prevent double submission
            setTimeout(() => {
                if (button.disabled) {
                    button.disabled = false;
                    buttonText.innerHTML = 'Join This Booth';
                }
            }, 10000); // Re-enable after 10 seconds if no response
        });

        // Auto-focus for better UX
        document.body.focus();

        // Add some visual feedback
        const joinButton = document.querySelector('button[type="submit"]');
        joinButton.addEventListener('mouseenter', function() {
            this.style.transform = 'translateY(-2px)';
        });
        joinButton.addEventListener('mouseleave', function() {
            this.style.transform = 'translateY(0)';
        });
    </script>
</body>
</html>