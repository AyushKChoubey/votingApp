<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard | VoteBooth</title>
    <link href="/public/css/tailwind.css" rel="stylesheet">
    
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="/public/css/animations.css" rel="stylesheet">
    <style>
        .booth-card {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .booth-card:hover {
            transform: translateY(-2px);
        }
        .booth-card.admin-card:hover {
            border-color: rgb(59 130 246 / 0.5);
            box-shadow: 0 10px 25px -5px rgb(59 130 246 / 0.1), 0 8px 10px -6px rgb(59 130 246 / 0.1);
        }
        .booth-card.member-card:hover {
            border-color: rgb(16 185 129 / 0.5);
            box-shadow: 0 10px 25px -5px rgb(16 185 129 / 0.1), 0 8px 10px -6px rgb(16 185 129 / 0.1);
        }
        .booth-card:hover .fa-click {
            transform: scale(1.1);
            transition: transform 0.2s ease;
        }
    </style>
</head>
<body class="bg-gradient-to-br from-slate-50 via-blue-50 to-indigo-50 min-h-screen font-sans">
    <!-- Navigation -->
    <nav class="bg-white/95 backdrop-blur-sm border-b border-slate-200 sticky top-0 z-50 shadow-sm">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-16">
                <!-- Logo -->
                <div class="flex items-center space-x-4">
                    <a href="/" class="flex items-center space-x-3">
                        <i class="fas fa-vote-yea text-2xl text-primary"></i>
                        <span class="font-bold text-xl text-slate-800">VoteBooth</span>
                    </a>
                    <div class="hidden md:flex items-center space-x-6 ml-8">
                        <a href="/booth/dashboard" class="text-primary font-semibold px-3 py-2 rounded-lg bg-blue-50">Dashboard</a>
                        <a href="/booth/create" class="text-slate-600 hover:text-primary transition-colors px-3 py-2 rounded-lg hover:bg-slate-100">Create Booth</a>
                        <a href="/booth/join" class="text-slate-600 hover:text-primary transition-colors px-3 py-2 rounded-lg hover:bg-slate-100">Join Booth</a>
                    </div>
                </div>
                
                <!-- User Menu -->
                <div class="flex items-center space-x-4">
                    <span class="text-sm text-slate-600">Welcome, <%= user.name %></span>
                    <div class="relative group">
                        <button class="flex items-center space-x-2 text-slate-600 hover:text-primary transition-colors p-2 rounded-lg hover:bg-slate-100">
                            <div class="w-8 h-8 bg-gradient-to-r from-blue-500 to-purple-600 rounded-full flex items-center justify-center text-white font-medium text-sm">
                                <%= user.name.charAt(0).toUpperCase() %>
                            </div>
                            <i class="fas fa-chevron-down text-sm"></i>
                        </button>
                        <div class="absolute right-0 mt-2 w-48 bg-white rounded-lg shadow-lg border border-slate-200 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
                            <a href="/user/profile" class="block px-4 py-2 text-slate-700 hover:bg-slate-50">
                                <i class="fas fa-user mr-2"></i>Profile
                            </a>
                            <a href="/user/settings" class="block px-4 py-2 text-slate-700 hover:bg-slate-50">
                                <i class="fas fa-cog mr-2"></i>Settings
                            </a>
                            <hr class="my-1">
                            <a href="/user/logout" class="block px-4 py-2 text-red-600 hover:bg-red-50">
                                <i class="fas fa-sign-out-alt mr-2"></i>Logout
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <!-- Welcome Header -->
        <div class="mb-8">
            <div class="flex flex-col md:flex-row md:items-center md:justify-between">
                <div>
                    <h1 class="text-3xl font-bold text-slate-900 mb-2">
                        <i class="fas fa-dashboard text-primary mr-3"></i>Dashboard
                    </h1>
                    <p class="text-slate-600">Manage your voting booths and participate in elections</p>
                </div>
                <div class="mt-4 md:mt-0">
                    <a href="/booth/create" class="bg-primary text-white px-6 py-3 rounded-xl font-semibold hover:bg-blue-700 transition-colors shadow-lg hover:shadow-xl transform hover:-translate-y-0.5">
                        <i class="fas fa-plus mr-2"></i>Create New Booth
                    </a>
                </div>
            </div>
        </div>

        <!-- Alert Messages -->
        <% if (message) { %>
            <div class="mb-6 bg-blue-50 border border-blue-200 rounded-xl p-4 animate-slide-down">
                <div class="flex items-center">
                    <div class="flex-shrink-0">
                        <i class="fas fa-info-circle text-blue-500 text-xl"></i>
                    </div>
                    <div class="ml-3">
                        <p class="text-blue-800 font-medium">
                            <% if (message === 'booth_created') { %>
                                Booth created successfully! Share the invite code with participants.
                            <% } else if (message === 'booth_updated') { %>
                                Booth updated successfully!
                            <% } else if (message === 'booth_deleted') { %>
                                Booth deleted successfully.
                            <% } else { %>
                                <%= message %>
                            <% } %>
                        </p>
                    </div>
                </div>
            </div>
        <% } %>

        <!-- Stats Overview -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
            <div class="bg-white rounded-xl p-6 shadow-sm border border-slate-200">
                <div class="flex items-center">
                    <div class="p-3 rounded-lg bg-blue-100">
                        <i class="fas fa-vote-yea text-blue-600 text-xl"></i>
                    </div>
                    <div class="ml-4">
                        <p class="text-sm font-medium text-slate-600">Created Booths</p>
                        <p class="text-2xl font-bold text-slate-900"><%= stats?.boothsCreated || 0 %></p>
                    </div>
                </div>
            </div>
            
            <div class="bg-white rounded-xl p-6 shadow-sm border border-slate-200">
                <div class="flex items-center">
                    <div class="p-3 rounded-lg bg-emerald-100">
                        <i class="fas fa-users text-emerald-600 text-xl"></i>
                    </div>
                    <div class="ml-4">
                        <p class="text-sm font-medium text-slate-600">Joined Booths</p>
                        <p class="text-2xl font-bold text-slate-900"><%= stats?.boothsJoined || 0 %></p>
                    </div>
                </div>
            </div>
            
            <div class="bg-white rounded-xl p-6 shadow-sm border border-slate-200">
                <div class="flex items-center">
                    <div class="p-3 rounded-lg bg-amber-100">
                        <i class="fas fa-chart-bar text-amber-600 text-xl"></i>
                    </div>
                    <div class="ml-4">
                        <p class="text-sm font-medium text-slate-600">Total Votes Cast</p>
                        <p class="text-2xl font-bold text-slate-900"><%= stats?.totalVotesCast || 0 %></p>
                    </div>
                </div>
            </div>
            
            <div class="bg-white rounded-xl p-6 shadow-sm border border-slate-200">
                <div class="flex items-center">
                    <div class="p-3 rounded-lg bg-purple-100">
                        <i class="fas fa-trophy text-purple-600 text-xl"></i>
                    </div>
                    <div class="ml-4">
                        <p class="text-sm font-medium text-slate-600">Total Members</p>
                        <p class="text-2xl font-bold text-slate-900"><%= stats?.totalMembers || 0 %></p>
                    </div>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            <!-- My Booths -->
            <div class="space-y-6">
                <div class="flex items-center justify-between">
                    <h2 class="text-xl font-bold text-slate-900">
                        <i class="fas fa-clipboard-list text-primary mr-2"></i>My Booths
                        <span class="text-sm font-normal text-slate-500">(<%= createdBooths.length %>)</span>
                    </h2>
                    <a href="/booth/create" class="text-primary hover:text-blue-700 text-sm font-medium">
                        <i class="fas fa-plus mr-1"></i>Create New
                    </a>
                </div>

                <div class="space-y-4">
                    <% if (createdBooths.length === 0) { %>
                        <div class="bg-white rounded-xl p-8 text-center border border-slate-200">
                            <i class="fas fa-vote-yea text-4xl text-slate-300 mb-4"></i>
                            <h3 class="text-lg font-semibold text-slate-600 mb-2">No booths created yet</h3>
                            <p class="text-slate-500 mb-6">Create your first voting booth to get started</p>
                            <a href="/booth/create" class="bg-primary text-white px-6 py-3 rounded-lg font-medium hover:bg-blue-700 transition-colors">
                                <i class="fas fa-plus mr-2"></i>Create Your First Booth
                            </a>
                        </div>
                    <% } else { %>
                        <% createdBooths.forEach(booth => { %>
                        <div class="booth-card admin-card bg-white rounded-xl p-6 shadow-sm border border-slate-200 cursor-pointer booth-clickable" data-admin-url="/booth/<%= booth._id %>/admin">
                            <div class="flex items-start justify-between mb-4">
                                <div class="flex-1">
                                    <div class="flex items-center space-x-3 mb-2">
                                        <h3 class="text-lg font-semibold text-slate-900"><%= booth.name %></h3>
                                        <span class="px-2 py-1 text-xs font-medium rounded-full <%= booth.status === 'active' ? 'bg-emerald-100 text-emerald-800' : booth.status === 'draft' ? 'bg-gray-100 text-gray-700' : booth.status === 'paused' ? 'bg-amber-100 text-amber-800' : 'bg-red-100 text-red-800' %>">
                                            <%= booth.status.charAt(0).toUpperCase() + booth.status.slice(1) %>
                                        </span>
                                    </div>
                                    <p class="text-slate-600 text-sm mb-3"><%= booth.description %></p>
                                </div>
                                <div class="relative">
                                    <button onclick="event.stopPropagation(); toggleDropdown('dropdown-<%= booth._id %>')" class="text-slate-400 hover:text-slate-600 p-2">
                                        <i class="fas fa-ellipsis-v"></i>
                                    </button>
                                    <div id="dropdown-<%= booth._id %>" class="absolute right-0 mt-2 w-48 bg-white rounded-lg shadow-lg border border-slate-200 opacity-0 invisible transition-all duration-200 z-10">
                                        <a href="/booth/<%= booth._id %>" class="block px-4 py-2 text-slate-700 hover:bg-slate-50">
                                            <i class="fas fa-eye mr-2"></i>View Booth
                                        </a>
                                        <a href="/booth/<%= booth._id %>/admin" class="block px-4 py-2 text-slate-700 hover:bg-slate-50">
                                            <i class="fas fa-cogs mr-2"></i>Admin Panel
                                        </a>
                                        <a href="/booth/<%= booth._id %>/results" class="block px-4 py-2 text-slate-700 hover:bg-slate-50">
                                            <i class="fas fa-chart-pie mr-2"></i>View Results
                                        </a>
                                        <hr class="my-1">
                                        <a href="/booth/<%= booth._id %>/edit" class="block px-4 py-2 text-slate-700 hover:bg-slate-50">
                                            <i class="fas fa-edit mr-2"></i>Edit
                                        </a>
                                        <button onclick="deleteBooth('<%= booth._id %>', '<%= booth.name %>')" class="w-full text-left block px-4 py-2 text-red-600 hover:bg-red-50">
                                            <i class="fas fa-trash mr-2"></i>Delete
                                        </button>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="flex items-center justify-between text-sm text-slate-500">
                                <div class="flex items-center space-x-4">
                                    <span><i class="fas fa-users mr-1"></i><%= booth.memberCount %> members</span>
                                    <span><i class="fas fa-vote-yea mr-1"></i><%= booth.totalVotes || 0 %> votes</span>
                                    <span><i class="fas fa-code mr-1"></i><%= booth.inviteCode %></span>
                                </div>
                                <div class="flex items-center space-x-2">
                                    <span class="text-xs text-slate-400"><i class="fas fa-click mr-1"></i>Click to manage</span>
                                    <span><%= new Date(booth.createdAt).toLocaleDateString() %></span>
                                </div>
                            </div>
                        </div>
                        <% }) %>
                    <% } %>
                </div>
            </div>

            <!-- Joined Booths -->
            <div class="space-y-6">
                <div class="flex items-center justify-between">
                    <h2 class="text-xl font-bold text-slate-900">
                        <i class="fas fa-user-friends text-emerald-600 mr-2"></i>Joined Booths
                        <span class="text-sm font-normal text-slate-500">(<%= joinedBooths.length %>)</span>
                    </h2>
                    <a href="/booth/join" class="text-emerald-600 hover:text-emerald-700 text-sm font-medium">
                        <i class="fas fa-plus mr-1"></i>Join Booth
                    </a>
                </div>

                <div class="space-y-4">
                    <% if (joinedBooths.length === 0) { %>
                        <div class="bg-white rounded-xl p-8 text-center border border-slate-200">
                            <i class="fas fa-user-friends text-4xl text-slate-300 mb-4"></i>
                            <h3 class="text-lg font-semibold text-slate-600 mb-2">No booths joined yet</h3>
                            <p class="text-slate-500 mb-6">Join a booth using an invite code</p>
                            <a href="/booth/join" class="bg-emerald-600 text-white px-6 py-3 rounded-lg font-medium hover:bg-emerald-700 transition-colors">
                                <i class="fas fa-plus mr-2"></i>Join a Booth
                            </a>
                        </div>
                    <% } else { %>
                        <% joinedBooths.forEach(booth => { %>
                        <div class="booth-card member-card bg-white rounded-xl p-6 shadow-sm border border-slate-200 cursor-pointer booth-clickable" data-vote-url="/booth/<%= booth._id %>">
                            <div class="flex items-start justify-between mb-4">
                                <div class="flex-1">
                                    <div class="flex items-center space-x-3 mb-2">
                                        <h3 class="text-lg font-semibold text-slate-900"><%= booth.name %></h3>
                                        <span class="px-2 py-1 text-xs font-medium rounded-full <%= booth.status === 'active' ? 'bg-emerald-100 text-emerald-800' : booth.status === 'draft' ? 'bg-gray-100 text-gray-700' : booth.status === 'paused' ? 'bg-amber-100 text-amber-800' : 'bg-red-100 text-red-800' %>">
                                            <%= booth.status.charAt(0).toUpperCase() + booth.status.slice(1) %>
                                        </span>
                                    </div>
                                    <p class="text-slate-600 text-sm mb-2"><%= booth.description %></p>
                                    <p class="text-xs text-slate-500">Created by <%= booth.creator.name %></p>
                                </div>
                                <div class="bg-emerald-100 text-emerald-700 px-4 py-2 rounded-lg font-medium">
                                    <i class="fas fa-vote-yea mr-2"></i>Vote
                                </div>
                            </div>
                            
                            <div class="flex items-center justify-between text-sm text-slate-500">
                                <div class="flex items-center space-x-4">
                                    <span><i class="fas fa-vote-yea mr-1"></i><%= booth.totalVotes || 0 %> votes</span>
                                </div>
                                <div class="flex items-center space-x-2">
                                    <span class="text-xs text-slate-400"><i class="fas fa-click mr-1"></i>Click to vote</span>
                                    <span><%= new Date(booth.createdAt).toLocaleDateString() %></span>
                                </div>
                            </div>
                        </div>
                        <% }) %>
                    <% } %>
                </div>
            </div>
        </div>

        <!-- Quick Actions -->
        <div class="mt-8 bg-white rounded-xl p-6 shadow-sm border border-slate-200">
            <h2 class="text-xl font-bold text-slate-900 mb-4">
                <i class="fas fa-bolt text-amber-500 mr-2"></i>Quick Actions
            </h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
                <a href="/booth/create" class="flex items-center space-x-3 p-4 border border-slate-200 rounded-lg hover:bg-slate-50 transition-colors">
                    <div class="p-2 bg-blue-100 rounded-lg">
                        <i class="fas fa-plus text-blue-600"></i>
                    </div>
                    <div>
                        <h3 class="font-medium text-slate-900">Create Booth</h3>
                        <p class="text-sm text-slate-500">Start new voting</p>
                    </div>
                </a>
                
                <a href="/booth/join" class="flex items-center space-x-3 p-4 border border-slate-200 rounded-lg hover:bg-slate-50 transition-colors">
                    <div class="p-2 bg-emerald-100 rounded-lg">
                        <i class="fas fa-sign-in-alt text-emerald-600"></i>
                    </div>
                    <div>
                        <h3 class="font-medium text-slate-900">Join Booth</h3>
                        <p class="text-sm text-slate-500">Enter invite code</p>
                    </div>
                </a>
                
                <a href="/user/profile" class="flex items-center space-x-3 p-4 border border-slate-200 rounded-lg hover:bg-slate-50 transition-colors">
                    <div class="p-2 bg-purple-100 rounded-lg">
                        <i class="fas fa-user text-purple-600"></i>
                    </div>
                    <div>
                        <h3 class="font-medium text-slate-900">Profile</h3>
                        <p class="text-sm text-slate-500">Manage account</p>
                    </div>
                </a>
                
                <a href="/help" class="flex items-center space-x-3 p-4 border border-slate-200 rounded-lg hover:bg-slate-50 transition-colors">
                    <div class="p-2 bg-amber-100 rounded-lg">
                        <i class="fas fa-question-circle text-amber-600"></i>
                    </div>
                    <div>
                        <h3 class="font-medium text-slate-900">Help</h3>
                        <p class="text-sm text-slate-500">Get support</p>
                    </div>
                </a>
            </div>
        </div>
    </div>

    <!-- Mobile Navigation -->
    <div class="md:hidden fixed bottom-0 left-0 right-0 bg-white border-t border-slate-200 px-4 py-2">
        <div class="flex justify-around">
            <a href="/booth/dashboard" class="flex flex-col items-center py-2 text-primary">
                <i class="fas fa-dashboard text-xl mb-1"></i>
                <span class="text-xs">Dashboard</span>
            </a>
            <a href="/booth/create" class="flex flex-col items-center py-2 text-slate-600">
                <i class="fas fa-plus text-xl mb-1"></i>
                <span class="text-xs">Create</span>
            </a>
            <a href="/booth/join" class="flex flex-col items-center py-2 text-slate-600">
                <i class="fas fa-sign-in-alt text-xl mb-1"></i>
                <span class="text-xs">Join</span>
            </a>
            <a href="/user/profile" class="flex flex-col items-center py-2 text-slate-600">
                <i class="fas fa-user text-xl mb-1"></i>
                <span class="text-xs">Profile</span>
            </a>
        </div>
    </div>

    <script>
        function toggleDropdown(dropdownId) {
            // Close all other dropdowns
            document.querySelectorAll('[id^="dropdown-"]').forEach(dropdown => {
                if (dropdown.id !== dropdownId) {
                    dropdown.classList.add('opacity-0', 'invisible');
                }
            });
            
            // Toggle current dropdown
            const dropdown = document.getElementById(dropdownId);
            dropdown.classList.toggle('opacity-0');
            dropdown.classList.toggle('invisible');
        }

        // Close dropdowns when clicking outside
        document.addEventListener('click', function(event) {
            if (!event.target.closest('button[onclick*="toggleDropdown"]') && !event.target.closest('[id^="dropdown-"]')) {
                document.querySelectorAll('[id^="dropdown-"]').forEach(dropdown => {
                    dropdown.classList.add('opacity-0', 'invisible');
                });
            }
        });

        function deleteBooth(boothId, boothName) {
            if (confirm(`Are you sure you want to delete "${boothName}"? This action cannot be undone.`)) {
                const form = document.createElement('form');
                form.method = 'POST';
                form.action = `/booth/${boothId}/delete`;
                document.body.appendChild(form);
                form.submit();
            }
        }

        // Add click handlers for booth cards
        document.addEventListener('DOMContentLoaded', function() {
            // Simple unified click handler
            document.querySelectorAll('.booth-clickable').forEach(function(card) {
                card.addEventListener('click', function(event) {
                    // Prevent if clicking on dropdown button or dropdown menu
                    if (event.target.closest('button') || event.target.closest('[id^="dropdown-"]')) {
                        return;
                    }
                    
                    // Get the URL from data attribute
                    const adminUrl = this.getAttribute('data-admin-url');
                    const voteUrl = this.getAttribute('data-vote-url');
                    const targetUrl = adminUrl || voteUrl;
                    
                    if (targetUrl) {
                        window.location.href = targetUrl;
                    }
                });
            });
        });
    </script>
</body>
</html>