<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Booth Dashboard - Voting App</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/animations.css">
</head>
<body class="min-h-screen bg-gradient-to-br from-blue-50 to-indigo-100">
    <!-- Navigation -->
    <nav class="bg-white shadow-sm border-b">
        <div class="max-w-6xl mx-auto px-6 py-4">
            <div class="flex justify-between items-center">
                <div class="flex items-center space-x-4">
                    <a href="/" class="text-2xl font-bold text-indigo-600">Voting App</a>
                    <span class="text-gray-300">|</span>
                    <span class="text-gray-600">Dashboard</span>
                </div>
                <div class="flex items-center space-x-4">
                    <span class="text-gray-600">Welcome, <%= user.name %></span>
                    <a href="/user/profile" class="text-indigo-600 hover:text-indigo-800">Profile</a>
                    <a href="/logout" class="bg-red-500 text-white px-4 py-2 rounded-lg hover:bg-red-600 transition-colors">Logout</a>
                </div>
            </div>
        </div>
    </nav>

    <div class="max-w-6xl mx-auto px-6 py-8">
        <!-- Header -->
        <div class="mb-8">
            <h1 class="text-3xl font-bold text-gray-900 mb-2">Your Booth Dashboard</h1>
            <p class="text-gray-600">Manage your voting booths and participate in others</p>
        </div>

        <!-- Quick Actions -->
        <div class="mb-8 flex flex-wrap gap-4">
            <a href="/booth/create" class="bg-indigo-600 text-white px-6 py-3 rounded-lg font-semibold hover:bg-indigo-700 transition-colors shadow-md">
                <svg class="w-5 h-5 inline-block mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
                </svg>
                Create New Booth
            </a>
            <a href="/booth/join" class="bg-green-600 text-white px-6 py-3 rounded-lg font-semibold hover:bg-green-700 transition-colors shadow-md">
                <svg class="w-5 h-5 inline-block mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                </svg>
                Join Booth
            </a>
        </div>

        <div class="grid lg:grid-cols-2 gap-8">
            <!-- Created Booths -->
            <div class="bg-white rounded-xl shadow-lg p-6">
                <h2 class="text-xl font-bold text-gray-900 mb-4 flex items-center">
                    <svg class="w-6 h-6 mr-2 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-6m-6 0H3m6 0h6"></path>
                    </svg>
                    Your Created Booths (<%= createdBooths.length %>)
                </h2>
                
                <% if (createdBooths.length === 0) { %>
                    <div class="text-center py-8 text-gray-500">
                        <svg class="w-16 h-16 mx-auto mb-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-6m-6 0H3m6 0h6"></path>
                        </svg>
                        <p class="text-lg mb-2">No booths created yet</p>
                        <p class="text-sm">Create your first voting booth to get started!</p>
                    </div>
                <% } else { %>
                    <div class="space-y-4">
                        <% createdBooths.forEach(booth => { %>
                            <div class="border border-gray-200 rounded-lg p-4 hover:shadow-md transition-shadow">
                                <div class="flex justify-between items-start mb-2">
                                    <h3 class="font-semibold text-lg text-gray-900"><%= booth.name %></h3>
                                    <span class="px-2 py-1 text-xs rounded-full <%= booth.status === 'active' ? 'bg-green-100 text-green-800' : booth.status === 'closed' ? 'bg-red-100 text-red-800' : 'bg-gray-100 text-gray-800' %>">
                                        <%= booth.status %>
                                    </span>
                                </div>
                                <p class="text-gray-600 text-sm mb-3"><%= booth.description %></p>
                                <div class="flex justify-between items-center">
                                    <div class="text-sm text-gray-500">
                                        <span class="mr-4">
                                            <svg class="w-4 h-4 inline-block mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z"></path>
                                            </svg>
                                            <%= booth.members ? booth.members.length : 0 %> members
                                        </span>
                                        <span>Code: <strong><%= booth.inviteCode %></strong></span>
                                    </div>
                                    <div class="flex space-x-2">
                                        <a href="/booth/<%= booth._id %>/admin" class="bg-blue-100 text-blue-700 px-3 py-1 rounded text-sm hover:bg-blue-200 transition-colors">Manage</a>
                                        <a href="/booth/<%= booth._id %>" class="bg-gray-100 text-gray-700 px-3 py-1 rounded text-sm hover:bg-gray-200 transition-colors">View</a>
                                        <a href="/booth/<%= booth._id %>/results" class="bg-purple-100 text-purple-700 px-3 py-1 rounded text-sm hover:bg-purple-200 transition-colors">Results</a>
                                    </div>
                                </div>
                            </div>
                        <% }); %>
                    </div>
                <% } %>
            </div>

            <!-- Joined Booths -->
            <div class="bg-white rounded-xl shadow-lg p-6">
                <h2 class="text-xl font-bold text-gray-900 mb-4 flex items-center">
                    <svg class="w-6 h-6 mr-2 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
                    </svg>
                    Joined Booths (<%= joinedBooths.length %>)
                </h2>
                
                <% if (joinedBooths.length === 0) { %>
                    <div class="text-center py-8 text-gray-500">
                        <svg class="w-16 h-16 mx-auto mb-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
                        </svg>
                        <p class="text-lg mb-2">No booths joined yet</p>
                        <p class="text-sm">Join voting booths using invite codes or links!</p>
                    </div>
                <% } else { %>
                    <div class="space-y-4">
                        <% joinedBooths.forEach(booth => { %>
                            <div class="border border-gray-200 rounded-lg p-4 hover:shadow-md transition-shadow">
                                <div class="flex justify-between items-start mb-2">
                                    <h3 class="font-semibold text-lg text-gray-900"><%= booth.name %></h3>
                                    <span class="px-2 py-1 text-xs rounded-full <%= booth.status === 'active' ? 'bg-green-100 text-green-800' : booth.status === 'closed' ? 'bg-red-100 text-red-800' : 'bg-gray-100 text-gray-800' %>">
                                        <%= booth.status %>
                                    </span>
                                </div>
                                <p class="text-gray-600 text-sm mb-3"><%= booth.description %></p>
                                <div class="flex justify-between items-center">
                                    <div class="text-sm text-gray-500">
                                        Status: <strong>Member</strong>
                                    </div>
                                    <div class="flex space-x-2">
                                        <a href="/booth/<%= booth._id %>" class="bg-indigo-100 text-indigo-700 px-3 py-1 rounded text-sm hover:bg-indigo-200 transition-colors">Vote</a>
                                        <a href="/booth/<%= booth._id %>/results" class="bg-purple-100 text-purple-700 px-3 py-1 rounded text-sm hover:bg-purple-200 transition-colors">Results</a>
                                    </div>
                                </div>
                            </div>
                        <% }); %>
                    </div>
                <% } %>
            </div>
        </div>

        <!-- Statistics -->
        <div class="mt-8 grid md:grid-cols-4 gap-6">
            <div class="bg-white rounded-lg p-6 shadow-md text-center">
                <div class="text-3xl font-bold text-indigo-600"><%= createdBooths.length %></div>
                <div class="text-gray-600">Booths Created</div>
            </div>
            <div class="bg-white rounded-lg p-6 shadow-md text-center">
                <div class="text-3xl font-bold text-green-600"><%= joinedBooths.length %></div>
                <div class="text-gray-600">Booths Joined</div>
            </div>
            <div class="bg-white rounded-lg p-6 shadow-md text-center">
                <div class="text-3xl font-bold text-purple-600">0</div>
                <div class="text-gray-600">Total Votes</div>
            </div>
            <div class="bg-white rounded-lg p-6 shadow-md text-center">
                <div class="text-3xl font-bold text-orange-600">
                    <%= createdBooths.filter(b => b.status === 'active').length %>
                </div>
                <div class="text-gray-600">Active Booths</div>
            </div>
        </div>
    </div>

    <script>
        // Add some interactive features
        document.addEventListener('DOMContentLoaded', function() {
            // Add fade-in animation to cards
            const cards = document.querySelectorAll('.bg-white');
            cards.forEach((card, index) => {
                card.style.animationDelay = `${index * 0.1}s`;
                card.classList.add('animate-fade-in');
            });
        });
    </script>
</body>
</html>
