<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Panel - <%= booth.name %> | VoteBooth</title>
    <link href="/public/css/tailwind.css" rel="stylesheet">
    
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link href="/public/css/animations.css" rel="stylesheet">
</head>
<body class="bg-gradient-to-br from-slate-50 via-blue-50 to-indigo-50 min-h-screen font-sans">
    <!-- Navigation -->
    <nav class="bg-white/95 backdrop-blur-sm border-b border-slate-200 sticky top-0 z-50 shadow-sm">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-16">
                <!-- Logo & Back -->
                <div class="flex items-center space-x-4">
                    <a href="/booth/dashboard" class="text-slate-600 hover:text-primary transition-colors p-2 rounded-lg hover:bg-slate-100">
                        <i class="fas fa-arrow-left text-lg"></i>
                    </a>
                    <div class="flex items-center">
                        <i class="fas fa-cogs text-2xl text-primary mr-3"></i>
                        <div>
                            <h1 class="font-bold text-xl text-slate-800">Admin Panel</h1>
                            <p class="text-sm text-slate-500"><%= booth.name %></p>
                        </div>
                    </div>
                </div>
                
                <!-- User Menu -->
                <div class="flex items-center space-x-4">
                    <span class="text-sm text-slate-600">Welcome, <%= user.name %></span>
                    <a href="/booth/<%= booth._id %>" class="bg-primary text-white px-4 py-2 rounded-lg font-medium hover:bg-blue-700 transition-colors">
                        <i class="fas fa-eye mr-2"></i>View Booth
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <!-- Header Stats -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
            <div class="bg-white rounded-xl p-6 shadow-sm border border-slate-200">
                <div class="flex items-center">
                    <div class="p-3 rounded-lg bg-blue-100">
                        <i class="fas fa-users text-blue-600 text-xl"></i>
                    </div>
                    <div class="ml-4">
                        <p class="text-sm font-medium text-slate-600">Total Members</p>
                        <p class="text-2xl font-bold text-slate-900"><%= booth.members.length %></p>
                    </div>
                </div>
            </div>
            
            <div class="bg-white rounded-xl p-6 shadow-sm border border-slate-200">
                <div class="flex items-center">
                    <div class="p-3 rounded-lg bg-emerald-100">
                        <i class="fas fa-vote-yea text-emerald-600 text-xl"></i>
                    </div>
                    <div class="ml-4">
                        <p class="text-sm font-medium text-slate-600">Total Votes</p>
                        <p class="text-2xl font-bold text-slate-900"><%= booth.totalVotes || 0 %></p>
                    </div>
                </div>
            </div>
            
            <div class="bg-white rounded-xl p-6 shadow-sm border border-slate-200">
                <div class="flex items-center">
                    <div class="p-3 rounded-lg bg-amber-100">
                        <i class="fas fa-chart-bar text-amber-600 text-xl"></i>
                    </div>
                    <div class="ml-4">
                        <p class="text-sm font-medium text-slate-600">Participation</p>
                        <p class="text-2xl font-bold text-slate-900"><%= Math.round((booth.totalVotes / Math.max(booth.members.length, 1)) * 100) %>%</p>
                    </div>
                </div>
            </div>
            
            <div class="bg-white rounded-xl p-6 shadow-sm border border-slate-200">
                <div class="flex items-center">
                    <div class="p-3 rounded-lg <%= booth.status === 'active' ? 'bg-emerald-100' : booth.status === 'draft' ? 'bg-gray-100' : 'bg-red-100' %>">
                        <i class="fas <%= booth.status === 'active' ? 'fa-play text-emerald-600' : booth.status === 'draft' ? 'fa-pause text-gray-600' : 'fa-stop text-red-600' %> text-xl"></i>
                    </div>
                    <div class="ml-4">
                        <p class="text-sm font-medium text-slate-600">Status</p>
                        <p class="text-lg font-bold capitalize <%= booth.status === 'active' ? 'text-emerald-600' : booth.status === 'draft' ? 'text-gray-600' : 'text-red-600' %>">
                            <%= booth.status %>
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <!-- Main Controls -->
            <div class="lg:col-span-2 space-y-6">
                <!-- Booth Controls -->
                <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
                    <div class="px-6 py-4 border-b border-slate-200">
                        <h3 class="text-lg font-semibold text-slate-900">Booth Controls</h3>
                        <p class="text-sm text-slate-600">Manage your booth settings and status</p>
                    </div>
                    <div class="p-6">
                        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                            <% if (booth.status === 'draft') { %>
                            <form method="POST" action="/booth/<%= booth._id %>/start" class="inline">
                                <button type="submit" class="w-full bg-emerald-600 text-white px-4 py-3 rounded-lg font-medium hover:bg-emerald-700 transition-colors">
                                    <i class="fas fa-play mr-2"></i>Start Voting
                                </button>
                            </form>
                            <% } else if (booth.status === 'active') { %>
                            <form method="POST" action="/booth/<%= booth._id %>/pause" class="inline">
                                <button type="submit" class="w-full bg-amber-600 text-white px-4 py-3 rounded-lg font-medium hover:bg-amber-700 transition-colors">
                                    <i class="fas fa-pause mr-2"></i>Pause Voting
                                </button>
                            </form>
                            <form method="POST" action="/booth/<%= booth._id %>/end" class="inline">
                                <button type="submit" class="w-full bg-red-600 text-white px-4 py-3 rounded-lg font-medium hover:bg-red-700 transition-colors" onclick="return confirm('Are you sure you want to end this booth? This cannot be undone.')">
                                    <i class="fas fa-stop mr-2"></i>End Booth
                                </button>
                            </form>
                            <% } else if (booth.status === 'paused') { %>
                            <form method="POST" action="/booth/<%= booth._id %>/resume" class="inline">
                                <button type="submit" class="w-full bg-emerald-600 text-white px-4 py-3 rounded-lg font-medium hover:bg-emerald-700 transition-colors">
                                    <i class="fas fa-play mr-2"></i>Resume
                                </button>
                            </form>
                            <form method="POST" action="/booth/<%= booth._id %>/end" class="inline">
                                <button type="submit" class="w-full bg-red-600 text-white px-4 py-3 rounded-lg font-medium hover:bg-red-700 transition-colors" onclick="return confirm('Are you sure you want to end this booth?')">
                                    <i class="fas fa-stop mr-2"></i>End Booth
                                </button>
                            </form>
                            <% } %>
                            
                            <a href="/booth/<%= booth._id %>/results" class="w-full bg-slate-600 text-white px-4 py-3 rounded-lg font-medium hover:bg-slate-700 transition-colors text-center">
                                <i class="fas fa-chart-pie mr-2"></i>View Results
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Members Management -->
                <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
                    <div class="px-6 py-4 border-b border-slate-200">
                        <h3 class="text-lg font-semibold text-slate-900">Members (<%= booth.members.length %>)</h3>
                        <p class="text-sm text-slate-600">Manage booth members and permissions</p>
                    </div>
                    <div class="divide-y divide-slate-200">
                        <% booth.members.forEach(member => { %>
                        <div class="px-6 py-4 flex items-center justify-between">
                            <div class="flex items-center space-x-3">
                                <div class="w-8 h-8 rounded-full bg-gradient-to-r from-blue-500 to-purple-600 flex items-center justify-center text-white font-medium text-sm">
                                    <%= member.user.name.charAt(0).toUpperCase() %>
                                </div>
                                <div>
                                    <p class="font-medium text-slate-900"><%= member.user.name %></p>
                                    <p class="text-sm text-slate-500"><%= member.user.email %></p>
                                </div>
                            </div>
                            <div class="flex items-center space-x-2">
                                <span class="text-xs px-2 py-1 rounded-full <%= member.hasVoted ? 'bg-emerald-100 text-emerald-800' : 'bg-slate-100 text-slate-600' %>">
                                    <%= member.hasVoted ? 'Voted' : 'Not Voted' %>
                                </span>
                                <span class="text-xs text-slate-500">
                                    Joined <%= new Date(member.joinedAt).toLocaleDateString() %>
                                </span>
                                <form method="POST" action="/booth/<%= booth._id %>/remove-member" class="inline">
                                    <input type="hidden" name="userId" value="<%= member.user._id %>">
                                    <button type="submit" class="text-red-600 hover:text-red-800 p-1" onclick="return confirm('Remove this member?')">
                                        <i class="fas fa-times"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                        <% }) %>
                    </div>
                </div>
            </div>

            <!-- Sidebar -->
            <div class="space-y-6">
                <!-- Invite Code -->
                <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6">
                    <h3 class="text-lg font-semibold text-slate-900 mb-4">Invite Members</h3>
                    <div class="space-y-4">
                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-2">Invite Code</label>
                            <div class="flex items-center space-x-2">
                                <input type="text" readonly value="<%= booth.inviteCode %>" 
                                       class="flex-1 px-3 py-2 border border-slate-300 rounded-lg bg-slate-50 font-mono text-center text-lg font-bold" 
                                       id="inviteCode">
                                <button onclick="copyInviteCode()" class="bg-slate-600 text-white px-3 py-2 rounded-lg hover:bg-slate-700 transition-colors">
                                    <i class="fas fa-copy"></i>
                                </button>
                            </div>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-2">Share Link</label>
                            <div class="flex items-center space-x-2">
                                <input type="text" readonly value="<%= process.env.BASE_URL || 'http://localhost:3000' %>/booth/join/<%= booth.inviteCode %>" 
                                       class="flex-1 px-3 py-2 border border-slate-300 rounded-lg bg-slate-50 text-sm" 
                                       id="shareLink">
                                <button onclick="copyShareLink()" class="bg-slate-600 text-white px-3 py-2 rounded-lg hover:bg-slate-700 transition-colors">
                                    <i class="fas fa-copy"></i>
                                </button>
                            </div>
                        </div>
                        <button onclick="regenerateCode()" class="w-full bg-amber-600 text-white px-4 py-2 rounded-lg font-medium hover:bg-amber-700 transition-colors">
                            <i class="fas fa-refresh mr-2"></i>Regenerate Code
                        </button>
                    </div>
                </div>

                <!-- Quick Actions -->
                <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6">
                    <h3 class="text-lg font-semibold text-slate-900 mb-4">Quick Actions</h3>
                    <div class="space-y-3">
                        <a href="/booth/<%= booth._id %>/edit" class="w-full flex items-center px-4 py-3 text-slate-700 hover:bg-slate-50 rounded-lg transition-colors">
                            <i class="fas fa-edit text-slate-500 w-5"></i>
                            <span class="ml-3">Edit Booth Details</span>
                        </a>
                        <button onclick="exportResults()" class="w-full flex items-center px-4 py-3 text-slate-700 hover:bg-slate-50 rounded-lg transition-colors">
                            <i class="fas fa-download text-slate-500 w-5"></i>
                            <span class="ml-3">Export Results</span>
                        </button>
                        <form method="POST" action="/booth/<%= booth._id %>/delete" class="inline w-full">
                            <button type="submit" class="w-full flex items-center px-4 py-3 text-red-700 hover:bg-red-50 rounded-lg transition-colors" onclick="return confirm('Are you sure you want to delete this booth? This cannot be undone.')">
                                <i class="fas fa-trash text-red-500 w-5"></i>
                                <span class="ml-3">Delete Booth</span>
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Toast Notifications -->
    <div id="toast-container" class="fixed top-4 right-4 z-50"></div>

    <script>
        function copyInviteCode() {
            const codeInput = document.getElementById('inviteCode');
            codeInput.select();
            document.execCommand('copy');
            showToast('Invite code copied to clipboard!', 'success');
        }

        function copyShareLink() {
            const linkInput = document.getElementById('shareLink');
            linkInput.select();
            document.execCommand('copy');
            showToast('Share link copied to clipboard!', 'success');
        }

        function regenerateCode() {
            if (confirm('Regenerate invite code? The old code will become invalid.')) {
                fetch('/booth/<%= booth._id %>/regenerate-code', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    }
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        document.getElementById('inviteCode').value = data.inviteCode;
                        document.getElementById('shareLink').value = 
                            `<%= process.env.BASE_URL || 'http://localhost:3000' %>/booth/join/${data.inviteCode}`;
                        showToast('Invite code regenerated successfully!', 'success');
                    } else {
                        showToast(data.error || 'Failed to regenerate code', 'error');
                    }
                })
                .catch(error => {
                    showToast('Failed to regenerate code', 'error');
                });
            }
        }

        function exportResults() {
            window.open('/booth/<%= booth._id %>/export', '_blank');
        }

        function showToast(message, type = 'info') {
            const toast = document.createElement('div');
            const bgClass = type === 'success' ? 'bg-emerald-600' : type === 'error' ? 'bg-red-600' : 'bg-blue-600';
            
            toast.className = `${bgClass} text-white px-6 py-3 rounded-lg shadow-lg transform translate-x-full transition-transform duration-300 mb-4`;
            toast.innerHTML = `
                <div class="flex items-center">
                    <i class="fas ${type === 'success' ? 'fa-check-circle' : type === 'error' ? 'fa-exclamation-circle' : 'fa-info-circle'} mr-3"></i>
                    <span>${message}</span>
                </div>
            `;
            
            document.getElementById('toast-container').appendChild(toast);
            
            setTimeout(() => {
                toast.style.transform = 'translateX(0)';
            }, 100);
            
            setTimeout(() => {
                toast.style.transform = 'translateX(100%)';
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }
    </script>
</body>
</html>