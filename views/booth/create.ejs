<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create New Booth | VoteBooth</title>
    <link href="/public/css/tailwind.css" rel="stylesheet">
    
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="/public/css/animations.css" rel="stylesheet">
</head>
<body class="bg-gradient-to-br from-slate-50 via-blue-50 to-indigo-50 min-h-screen font-sans">
    <!-- Navigation -->
    <nav class="bg-white/95 backdrop-blur-sm border-b border-slate-200 sticky top-0 z-50 shadow-sm">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-16">
                <!-- Logo & Back -->
                <div class="flex items-center space-x-4">
                    <a href="/booth/dashboard" class="text-slate-600 hover:text-primary transition-colors p-2 rounded-lg hover:bg-slate-100">
                        <i class="fas fa-arrow-left text-lg"></i>
                    </a>
                    <div class="flex items-center">
                        <i class="fas fa-plus-circle text-2xl text-primary mr-3"></i>
                        <div>
                            <h1 class="font-bold text-xl text-slate-800">Create New Booth</h1>
                            <p class="text-sm text-slate-500">Set up a new voting booth</p>
                        </div>
                    </div>
                </div>
                
                <!-- User Menu -->
                <div class="flex items-center space-x-4">
                    <span class="text-sm text-slate-600">Welcome, <%= user && user.name ? user.name : 'User' %></span>
                    <a href="/booth/dashboard" class="bg-slate-600 text-white px-4 py-2 rounded-lg font-medium hover:bg-slate-700 transition-colors">
                        <i class="fas fa-dashboard mr-2"></i>Dashboard
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <!-- Alert Messages -->
        <% if (error) { %>
            <div class="mb-6 bg-red-50 border border-red-200 rounded-xl p-4 animate-slide-down">
                <div class="flex items-center">
                    <div class="flex-shrink-0">
                        <i class="fas fa-exclamation-circle text-red-500 text-xl"></i>
                    </div>
                    <div class="ml-3">
                        <p class="text-red-800 font-medium"><%= error %></p>
                    </div>
                </div>
            </div>
        <% } %>

        <% if (success) { %>
            <div class="mb-6 bg-emerald-50 border border-emerald-200 rounded-xl p-4 animate-slide-down">
                <div class="flex items-center">
                    <div class="flex-shrink-0">
                        <i class="fas fa-check-circle text-emerald-500 text-xl"></i>
                    </div>
                    <div class="ml-3">
                        <p class="text-emerald-800 font-medium"><%= success %></p>
                    </div>
                </div>
            </div>
        <% } %>

        <% if (typeof canCreate !== 'undefined' && !canCreate) { %>
            <div class="bg-amber-50 border border-amber-200 rounded-xl p-6 mb-8">
                <div class="flex items-center">
                    <div class="flex-shrink-0">
                        <i class="fas fa-exclamation-triangle text-amber-500 text-2xl"></i>
                    </div>
                    <div class="ml-4">
                        <h3 class="text-lg font-semibold text-amber-800 mb-2">Booth Creation Limit Reached</h3>
                        <p class="text-amber-700 mb-4">
                            You've reached your maximum limit of <%= typeof maxBooths !== 'undefined' ? maxBooths : 5 %> booths. 
                            Upgrade your account to create more booths.
                        </p>
                        <div class="flex space-x-3">
                            <a href="/pricing" class="bg-amber-600 text-white px-4 py-2 rounded-lg font-medium hover:bg-amber-700 transition-colors">
                                <i class="fas fa-crown mr-2"></i>Upgrade Account
                            </a>
                            <a href="/booth/dashboard" class="bg-white text-amber-700 border border-amber-300 px-4 py-2 rounded-lg font-medium hover:bg-amber-50 transition-colors">
                                Back to Dashboard
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        <% } else { %>
            <!-- Create Booth Form -->
            <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
                <form method="POST" action="/booth/create" id="createBoothForm">
                    <!-- CSRF token will be added when middleware is working -->
                    <!-- Form Header -->
                    <div class="px-8 py-6 border-b border-slate-200 bg-gradient-to-r from-blue-50 to-indigo-50">
                        <div class="flex items-center space-x-3">
                            <div class="p-3 bg-blue-100 rounded-lg">
                                <i class="fas fa-vote-yea text-blue-600 text-xl"></i>
                            </div>
                            <div>
                                <h2 class="text-xl font-bold text-slate-800">Booth Details</h2>
                                <p class="text-slate-600">Configure your voting booth settings</p>
                            </div>
                        </div>
                    </div>

                    <div class="p-8 space-y-8">
                        <!-- Basic Information -->
                        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                            <div>
                                <label for="name" class="block text-sm font-semibold text-slate-700 mb-2">
                                    <i class="fas fa-tag text-slate-500 mr-2"></i>Booth Name *
                                </label>
                                <input type="text" id="name" name="name" required 
                                       class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors"
                                       placeholder="Enter booth name (e.g., Class President Election)">
                                <p class="text-xs text-slate-500 mt-1">3-100 characters</p>
                            </div>

                            <div>
                                <label for="maxMembers" class="block text-sm font-semibold text-slate-700 mb-2">
                                    <i class="fas fa-users text-slate-500 mr-2"></i>Maximum Members
                                </label>
                                <input type="number" id="maxMembers" name="maxMembers" min="2" max="10000" value="100"
                                       class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors"
                                       placeholder="100">
                                <p class="text-xs text-slate-500 mt-1">2-10,000 members</p>
                            </div>
                        </div>

                        <div>
                            <label for="description" class="block text-sm font-semibold text-slate-700 mb-2">
                                <i class="fas fa-align-left text-slate-500 mr-2"></i>Description *
                            </label>
                            <textarea id="description" name="description" rows="3" required
                                      class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors"
                                      placeholder="Describe what this booth is for, voting rules, etc. (10-500 characters)"></textarea>
                            <p class="text-xs text-slate-500 mt-1">10-500 characters</p>
                        </div>

                        <!-- Candidates Section -->
                        <div>
                            <div class="flex items-center justify-between mb-4">
                                <div>
                                    <h3 class="text-lg font-semibold text-slate-800">
                                        <i class="fas fa-user-friends text-slate-500 mr-2"></i>Candidates
                                    </h3>
                                    <p class="text-sm text-slate-600">Add candidates or options for voting (minimum 2)</p>
                                </div>
                                <button type="button" onclick="addCandidate()" 
                                        class="bg-emerald-600 text-white px-4 py-2 rounded-lg font-medium hover:bg-emerald-700 transition-colors">
                                    <i class="fas fa-plus mr-2"></i>Add Candidate
                                </button>
                            </div>

                            <div id="candidates-container" class="space-y-3">
                                <!-- Initial candidates will be added by JavaScript -->
                            </div>
                        </div>

                        <!-- Settings -->
                        <div>
                            <h3 class="text-lg font-semibold text-slate-800 mb-4">
                                <i class="fas fa-cog text-slate-500 mr-2"></i>Booth Settings
                            </h3>
                            
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div class="space-y-4">
                                    <div class="flex items-center justify-between p-4 border border-slate-200 rounded-lg">
                                        <div>
                                            <label for="anonymousVoting" class="font-medium text-slate-700">Anonymous Voting</label>
                                            <p class="text-sm text-slate-500">Hide voter identities in results</p>
                                        </div>
                                        <label class="relative inline-flex items-center cursor-pointer">
                                            <input type="checkbox" id="anonymousVoting" name="settings[anonymousVoting]" class="sr-only peer" checked>
                                            <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-blue-300 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-blue-600"></div>
                                        </label>
                                    </div>

                                    <div class="flex items-center justify-between p-4 border border-slate-200 rounded-lg">
                                        <div>
                                            <label for="allowViewResults" class="font-medium text-slate-700">Results Visible to Voters</label>
                                            <p class="text-sm text-slate-500">Allow voters to see results</p>
                                        </div>
                                        <label class="relative inline-flex items-center cursor-pointer">
                                            <input type="checkbox" id="allowViewResults" name="settings[allowViewResults]" class="sr-only peer">
                                            <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-blue-300 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-blue-600"></div>
                                        </label>
                                    </div>
                                </div>

                                <div class="space-y-4">
                                    <div class="flex items-center justify-between p-4 border border-slate-200 rounded-lg">
                                        <div>
                                            <label for="allowMultipleVotes" class="font-medium text-slate-700">Allow Vote Changes</label>
                                            <p class="text-sm text-slate-500">Let users change their vote</p>
                                        </div>
                                        <label class="relative inline-flex items-center cursor-pointer">
                                            <input type="checkbox" id="allowMultipleVotes" name="settings[allowMultipleVotes]" class="sr-only peer">
                                            <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-blue-300 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-blue-600"></div>
                                        </label>
                                    </div>

                                    <div class="flex items-center justify-between p-4 border border-slate-200 rounded-lg">
                                        <div>
                                            <label for="requireApproval" class="font-medium text-slate-700">Require Join Approval</label>
                                            <p class="text-sm text-slate-500">Manually approve new members</p>
                                        </div>
                                        <label class="relative inline-flex items-center cursor-pointer">
                                            <input type="checkbox" id="requireApproval" name="settings[requireApproval]" class="sr-only peer">
                                            <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-blue-300 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-blue-600"></div>
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Form Actions -->
                        <div class="flex flex-col sm:flex-row gap-4 pt-6 border-t border-slate-200">
                            <button type="submit" 
                                    class="flex-1 bg-primary text-white px-6 py-4 rounded-xl font-semibold text-lg hover:bg-blue-700 transition-colors shadow-lg hover:shadow-xl transform hover:-translate-y-0.5">
                                <i class="fas fa-rocket mr-3"></i>Create Booth
                            </button>
                            <button type="button" onclick="saveDraft()"
                                    class="flex-1 bg-slate-600 text-white px-6 py-4 rounded-xl font-semibold text-lg hover:bg-slate-700 transition-colors">
                                <i class="fas fa-save mr-3"></i>Save as Draft
                            </button>
                            <a href="/booth/dashboard" 
                               class="flex-1 bg-white text-slate-700 border border-slate-300 px-6 py-4 rounded-xl font-semibold text-lg hover:bg-slate-50 transition-colors text-center">
                                <i class="fas fa-times mr-3"></i>Cancel
                            </a>
                        </div>
                    </div>
                </form>
            </div>
        <% } %>
    </div>

    <script>
        let candidateCount = 0;

        // Initialize with 2 candidates
        document.addEventListener('DOMContentLoaded', function() {
            addCandidate();
            addCandidate();
        });

        function addCandidate() {
            candidateCount++;
            const container = document.getElementById('candidates-container');
            const candidateDiv = document.createElement('div');
            candidateDiv.className = 'candidate-item flex items-center space-x-3 p-4 border border-slate-200 rounded-lg bg-slate-50';
            candidateDiv.innerHTML = `
                <div class="flex-shrink-0 w-8 h-8 bg-gradient-to-r from-blue-500 to-purple-600 rounded-full flex items-center justify-center text-white font-bold text-sm">
                    ${candidateCount}
                </div>
                <div class="flex-1">
                    <input type="text" name="candidates[${candidateCount - 1}][name]" required 
                           placeholder="Candidate ${candidateCount} name" 
                           class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors">
                </div>
                <button type="button" onclick="removeCandidate(this)" 
                        class="flex-shrink-0 text-red-600 hover:text-red-800 p-2 rounded-lg hover:bg-red-50 transition-colors ${candidateCount <= 2 ? 'opacity-50 cursor-not-allowed' : ''}">
                    <i class="fas fa-trash-alt"></i>
                </button>
            `;
            container.appendChild(candidateDiv);
            updateRemoveButtons();
        }

        function removeCandidate(button) {
            const container = document.getElementById('candidates-container');
            if (container.children.length <= 2) {
                alert('You must have at least 2 candidates');
                return;
            }
            button.closest('.candidate-item').remove();
            updateCandidateNumbers();
            updateRemoveButtons();
        }

        function updateCandidateNumbers() {
            const candidates = document.querySelectorAll('.candidate-item');
            candidates.forEach((candidate, index) => {
                const numberDiv = candidate.querySelector('.flex-shrink-0');
                numberDiv.textContent = index + 1;
                const input = candidate.querySelector('input');
                input.name = `candidates[${index}][name]`;
                input.placeholder = `Candidate ${index + 1} name`;
            });
        }

        function updateRemoveButtons() {
            const candidates = document.querySelectorAll('.candidate-item');
            candidates.forEach(candidate => {
                const removeBtn = candidate.querySelector('button[onclick*="removeCandidate"]');
                if (candidates.length <= 2) {
                    removeBtn.classList.add('opacity-50', 'cursor-not-allowed');
                } else {
                    removeBtn.classList.remove('opacity-50', 'cursor-not-allowed');
                }
            });
        }

        function saveDraft() {
            const form = document.getElementById('createBoothForm');
            const hiddenInput = document.createElement('input');
            hiddenInput.type = 'hidden';
            hiddenInput.name = 'draft';
            hiddenInput.value = 'true';
            form.appendChild(hiddenInput);
            form.submit();
        }

        // Form validation
        document.getElementById('createBoothForm').addEventListener('submit', function(e) {
            const name = document.getElementById('name').value.trim();
            const description = document.getElementById('description').value.trim();
            const candidates = document.querySelectorAll('input[name*="candidates"]');
            
            let valid = true;
            let errors = [];

            if (name.length < 3 || name.length > 100) {
                errors.push('Booth name must be 3-100 characters');
                valid = false;
            }

            if (description.length < 10 || description.length > 500) {
                errors.push('Description must be 10-500 characters');
                valid = false;
            }

            let validCandidates = 0;
            candidates.forEach(input => {
                if (input.value.trim().length > 0) validCandidates++;
            });

            if (validCandidates < 2) {
                errors.push('You must have at least 2 candidates with names');
                valid = false;
            }

            if (!valid) {
                e.preventDefault();
                alert('Please fix the following errors:\n\n' + errors.join('\n'));
            }
        });
    </script>
</body>
</html>