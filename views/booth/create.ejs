<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Booth - Voting App</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/animations.css">
</head>
<body class="min-h-screen bg-gradient-to-br from-blue-50 to-indigo-100">
    <!-- Navigation -->
    <nav class="bg-white shadow-sm border-b">
        <div class="max-w-6xl mx-auto px-6 py-4">
            <div class="flex justify-between items-center">
                <div class="flex items-center space-x-4">
                    <a href="/" class="text-2xl font-bold text-indigo-600">Voting App</a>
                    <span class="text-gray-300">|</span>
                    <a href="/booth/dashboard" class="text-gray-600 hover:text-gray-800">Dashboard</a>
                    <span class="text-gray-300">|</span>
                    <span class="text-gray-600">Create Booth</span>
                </div>
                <div class="flex items-center space-x-4">
                    <a href="/booth/dashboard" class="text-indigo-600 hover:text-indigo-800">Back to Dashboard</a>
                    <a href="/logout" class="bg-red-500 text-white px-4 py-2 rounded-lg hover:bg-red-600 transition-colors">Logout</a>
                </div>
            </div>
        </div>
    </nav>

    <div class="max-w-4xl mx-auto px-6 py-8">
        <!-- Header -->
        <div class="mb-8">
            <h1 class="text-3xl font-bold text-gray-900 mb-2">Create a New Voting Booth</h1>
            <p class="text-gray-600">Set up your voting booth with candidates and settings</p>
        </div>

        <!-- Error/Success Messages -->
        <% if (typeof error !== 'undefined' && error) { %>
            <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-6">
                <%= error %>
            </div>
        <% } %>
        <% if (typeof success !== 'undefined' && success) { %>
            <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-6">
                <%= success %>
            </div>
        <% } %>

        <form id="createBoothForm" action="/booth/create" method="POST" class="bg-white rounded-xl shadow-lg p-8">
            <!-- Basic Information -->
            <div class="mb-8">
                <h2 class="text-xl font-semibold text-gray-900 mb-4">Basic Information</h2>
                <div class="grid md:grid-cols-2 gap-6">
                    <div>
                        <label for="name" class="block text-sm font-medium text-gray-700 mb-2">Booth Name *</label>
                        <input type="text" id="name" name="name" required
                               class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500"
                               placeholder="e.g., Student Council Elections 2024">
                    </div>
                    <div>
                        <label for="maxMembers" class="block text-sm font-medium text-gray-700 mb-2">Max Members</label>
                        <input type="number" id="maxMembers" name="maxMembers" min="1" max="10000" value="100"
                               class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500"
                               placeholder="100">
                    </div>
                </div>
                <div class="mt-6">
                    <label for="description" class="block text-sm font-medium text-gray-700 mb-2">Description *</label>
                    <textarea id="description" name="description" rows="3" required
                              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500"
                              placeholder="Describe what this booth is for and any voting instructions..."></textarea>
                </div>
            </div>

            <!-- Candidates Section -->
            <div class="mb-8">
                <h2 class="text-xl font-semibold text-gray-900 mb-4">Candidates</h2>
                <div id="candidatesContainer">
                    <div class="candidate-item mb-4 p-4 border border-gray-200 rounded-lg">
                        <div class="flex justify-between items-center mb-2">
                            <h3 class="font-medium text-gray-900">Candidate 1</h3>
                            <button type="button" class="remove-candidate text-red-500 hover:text-red-700 hidden">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                                </svg>
                            </button>
                        </div>
                        <div class="grid md:grid-cols-2 gap-4">
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1">Name *</label>
                                <input type="text" name="candidates[0][name]" required
                                       class="w-full px-3 py-2 border border-gray-300 rounded focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500"
                                       placeholder="Candidate name">
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1">Description</label>
                                <input type="text" name="candidates[0][description]"
                                       class="w-full px-3 py-2 border border-gray-300 rounded focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500"
                                       placeholder="Brief description or slogan">
                            </div>
                        </div>
                    </div>
                </div>
                <button type="button" id="addCandidate" class="bg-green-500 text-white px-4 py-2 rounded-lg hover:bg-green-600 transition-colors">
                    <svg class="w-5 h-5 inline-block mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
                    </svg>
                    Add Candidate
                </button>
            </div>

            <!-- Settings Section -->
            <div class="mb-8">
                <h2 class="text-xl font-semibold text-gray-900 mb-4">Booth Settings</h2>
                <div class="grid md:grid-cols-2 gap-6">
                    <!-- Left Column - Voting Settings -->
                    <div class="space-y-4">
                        <h3 class="text-md font-medium text-gray-800 border-b pb-2">Voting Rules</h3>
                        <div class="flex items-center">
                            <input type="checkbox" id="resultsVisibleToVoters" name="settings[resultsVisibleToVoters]" checked
                                   class="h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded">
                            <label for="resultsVisibleToVoters" class="ml-2 block text-sm text-gray-900">
                                Results visible to voters after voting
                            </label>
                        </div>
                        <div class="flex items-center">
                            <input type="checkbox" id="anonymousVoting" name="settings[anonymousVoting]" checked
                                   class="h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded">
                            <label for="anonymousVoting" class="ml-2 block text-sm text-gray-900">
                                Anonymous voting (votes are not linked to users)
                            </label>
                        </div>
                        <div class="flex items-center">
                            <input type="checkbox" id="allowVoteChange" name="settings[allowVoteChange]"
                                   class="h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded">
                            <label for="allowVoteChange" class="ml-2 block text-sm text-gray-900">
                                Allow voters to change their vote
                            </label>
                        </div>
                        <div class="flex items-center">
                            <input type="checkbox" id="showLiveResults" name="settings[showLiveResults]"
                                   class="h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded">
                            <label for="showLiveResults" class="ml-2 block text-sm text-gray-900">
                                Show live results during voting
                            </label>
                        </div>
                    </div>
                    
                    <!-- Right Column - Access Control -->
                    <div class="space-y-4">
                        <h3 class="text-md font-medium text-gray-800 border-b pb-2">Access Control</h3>
                        <div class="flex items-center">
                            <input type="checkbox" id="requireEmailVerification" name="settings[requireEmailVerification]"
                                   class="h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded">
                            <label for="requireEmailVerification" class="ml-2 block text-sm text-gray-900">
                                Require email verification to join
                            </label>
                        </div>
                        <div class="flex items-center">
                            <input type="checkbox" id="requireApproval" name="settings[requireApproval]"
                                   class="h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded">
                            <label for="requireApproval" class="ml-2 block text-sm text-gray-900">
                                Require admin approval to join
                            </label>
                        </div>
                        <div class="flex items-center">
                            <input type="checkbox" id="publicBooth" name="settings[publicBooth]"
                                   class="h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded">
                            <label for="publicBooth" class="ml-2 block text-sm text-gray-900">
                                Make booth discoverable (public listing)
                            </label>
                        </div>
                        <div class="flex items-center">
                            <input type="checkbox" id="sendNotifications" name="settings[sendNotifications]"
                                   class="h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded">
                            <label for="sendNotifications" class="ml-2 block text-sm text-gray-900">
                                Send email notifications to members
                            </label>
                        </div>
                    </div>
                </div>
                
                <!-- Time Settings Row -->
                <div class="grid md:grid-cols-2 gap-6 mt-6">
                    <div>
                        <label for="votingStartTime" class="block text-sm font-medium text-gray-700 mb-2">Voting Start Time (optional)</label>
                        <input type="datetime-local" id="votingStartTime" name="settings[votingStartTime]"
                               class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500">
                        <p class="text-xs text-gray-500 mt-1">Leave empty to start immediately</p>
                    </div>
                    <div>
                        <label for="votingEndTime" class="block text-sm font-medium text-gray-700 mb-2">Voting End Time (optional)</label>
                        <input type="datetime-local" id="votingEndTime" name="settings[votingEndTime]"
                               class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500">
                        <p class="text-xs text-gray-500 mt-1">Leave empty for no deadline</p>
                    </div>
                </div>
                
                <!-- Email Domain Restriction -->
                <div class="mt-6">
                    <div class="flex items-center mb-3">
                        <input type="checkbox" id="enableEmailRestriction" 
                               class="h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded"
                               onchange="toggleEmailRestriction()">
                        <label for="enableEmailRestriction" class="ml-2 block text-sm font-medium text-gray-700">
                            <span class="font-medium">Restrict by Email Domain</span>
                            <span class="text-gray-500 text-xs block">Only allow users from specific email domains</span>
                        </label>
                    </div>
                    <div id="emailRestrictionField" style="display: none;" class="mt-3">
                        <label for="allowedEmailDomains" class="block text-sm font-medium text-gray-700 mb-2">Allowed Email Domains</label>
                        <input type="text" id="allowedEmailDomains" name="settings[allowedEmailDomains]"
                               class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500"
                               placeholder="e.g., gmail.com, @college.edu, company.com"
                               disabled>
                        <p class="text-xs text-gray-500 mt-1">Comma-separated list of domains (with or without @)</p>
                    </div>
                </div>
            </div>

            <!-- Submit Button -->
            <div class="flex justify-end space-x-4">
                <a href="/booth/dashboard" class="bg-gray-300 text-gray-700 px-6 py-3 rounded-lg font-semibold hover:bg-gray-400 transition-colors">Cancel</a>
                <button type="submit" class="bg-indigo-600 text-white px-6 py-3 rounded-lg font-semibold hover:bg-indigo-700 transition-colors">
                    Create Booth
                </button>
            </div>
        </form>
    </div>

    <script>
        let candidateCount = 1;

        document.getElementById('addCandidate').addEventListener('click', function() {
            const container = document.getElementById('candidatesContainer');
            const newCandidate = document.createElement('div');
            newCandidate.className = 'candidate-item mb-4 p-4 border border-gray-200 rounded-lg';
            newCandidate.innerHTML = `
                <div class="flex justify-between items-center mb-2">
                    <h3 class="font-medium text-gray-900">Candidate ${candidateCount + 1}</h3>
                    <button type="button" class="remove-candidate text-red-500 hover:text-red-700">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                        </svg>
                    </button>
                </div>
                <div class="grid md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Name *</label>
                        <input type="text" name="candidates[${candidateCount}][name]" required
                               class="w-full px-3 py-2 border border-gray-300 rounded focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500"
                               placeholder="Candidate name">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Description</label>
                        <input type="text" name="candidates[${candidateCount}][description]"
                               class="w-full px-3 py-2 border border-gray-300 rounded focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500"
                               placeholder="Brief description or slogan">
                    </div>
                </div>
            `;
            
            container.appendChild(newCandidate);
            candidateCount++;
            
            // Show remove buttons if there's more than one candidate
            updateRemoveButtons();
        });

        // Handle remove candidate
        document.addEventListener('click', function(e) {
            if (e.target.closest('.remove-candidate')) {
                e.target.closest('.candidate-item').remove();
                updateRemoveButtons();
                renumberCandidates();
            }
        });

        function updateRemoveButtons() {
            const candidates = document.querySelectorAll('.candidate-item');
            const removeButtons = document.querySelectorAll('.remove-candidate');
            
            removeButtons.forEach(button => {
                button.classList.toggle('hidden', candidates.length <= 1);
            });
        }

        function renumberCandidates() {
            const candidates = document.querySelectorAll('.candidate-item');
            candidates.forEach((candidate, index) => {
                const title = candidate.querySelector('h3');
                title.textContent = `Candidate ${index + 1}`;
                
                const nameInput = candidate.querySelector('input[name*="[name]"]');
                const descInput = candidate.querySelector('input[name*="[description]"]');
                
                nameInput.name = `candidates[${index}][name]`;
                descInput.name = `candidates[${index}][description]`;
            });
            
            candidateCount = candidates.length;
        }

        // Form submission handling
        document.getElementById('createBoothForm').addEventListener('submit', function(e) {
            const candidates = document.querySelectorAll('input[name*="[name]"]');
            if (candidates.length < 2) {
                e.preventDefault();
                alert('You need at least 2 candidates to create a booth.');
                return;
            }

            // Validate that all candidate names are filled
            let hasEmptyName = false;
            candidates.forEach(input => {
                if (!input.value.trim()) {
                    hasEmptyName = true;
                }
            });

            if (hasEmptyName) {
                e.preventDefault();
                alert('Please fill in all candidate names.');
                return;
            }

            // Show loading state
            const submitBtn = this.querySelector('button[type="submit"]');
            submitBtn.textContent = 'Creating...';
            submitBtn.disabled = true;
        });

        // Toggle email restriction field
        function toggleEmailRestriction() {            const checkbox = document.getElementById('enableEmailRestriction');
            const field = document.getElementById('emailRestrictionField');
            const input = document.getElementById('allowedEmailDomains');
            
            if (checkbox.checked) {
                field.style.display = 'block';
                input.disabled = false;
            } else {
                field.style.display = 'none';
                input.disabled = true;
                input.value = ''; // Clear the value when disabled
            }
        }
    </script>
</body>
</html>
