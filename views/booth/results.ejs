<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Results - <%= booth.name %> - Voting App</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link rel="stylesheet" href="/css/animations.css">
</head>
<body class="min-h-screen bg-gradient-to-br from-blue-50 to-indigo-100">
    <!-- Navigation -->
    <nav class="bg-white shadow-sm border-b">
        <div class="max-w-6xl mx-auto px-6 py-4">
            <div class="flex justify-between items-center">
                <div class="flex items-center space-x-4">
                    <a href="/" class="text-2xl font-bold text-indigo-600">Voting App</a>
                    <span class="text-gray-300">|</span>
                    <a href="/booth/dashboard" class="text-gray-600 hover:text-gray-800">Dashboard</a>
                    <span class="text-gray-300">|</span>
                    <a href="/booth/<%= booth._id %>" class="text-gray-600 hover:text-gray-800"><%= booth.name %></a>
                    <span class="text-gray-300">|</span>
                    <span class="text-gray-600">Results</span>
                </div>
                <div class="flex items-center space-x-4">
                    <% if (isCreator) { %>
                        <a href="/booth/<%= booth._id %>/admin" class="bg-blue-500 text-white px-4 py-2 rounded-lg hover:bg-blue-600 transition-colors">Admin Panel</a>
                    <% } %>
                    <a href="/booth/<%= booth._id %>" class="text-indigo-600 hover:text-indigo-800">Back to Booth</a>
                    <a href="/logout" class="bg-red-500 text-white px-4 py-2 rounded-lg hover:bg-red-600 transition-colors">Logout</a>
                </div>
            </div>
        </div>
    </nav>

    <div class="max-w-6xl mx-auto px-6 py-8">
        <!-- Header -->
        <div class="bg-white rounded-xl shadow-lg p-8 mb-8">
            <div class="text-center mb-6">
                <h1 class="text-3xl font-bold text-gray-900 mb-2">Voting Results</h1>
                <h2 class="text-xl text-gray-600 mb-4"><%= booth.name %></h2>
                <p class="text-gray-500"><%= booth.description %></p>
            </div>

            <!-- Stats Overview -->
            <div class="grid md:grid-cols-4 gap-6">
                <div class="text-center p-4 bg-gray-50 rounded-lg">
                    <div class="text-3xl font-bold text-indigo-600"><%= totalVotes %></div>
                    <div class="text-gray-600">Total Votes</div>
                </div>
                <div class="text-center p-4 bg-gray-50 rounded-lg">
                    <div class="text-3xl font-bold text-green-600"><%= booth.members.length %></div>
                    <div class="text-gray-600">Total Members</div>
                </div>
                <div class="text-center p-4 bg-gray-50 rounded-lg">
                    <div class="text-3xl font-bold text-purple-600">
                        <%= booth.members.length > 0 ? Math.round((totalVotes / booth.members.length) * 100) : 0 %>%
                    </div>
                    <div class="text-gray-600">Participation Rate</div>
                </div>
                <div class="text-center p-4 bg-gray-50 rounded-lg">
                    <div class="text-3xl font-bold text-orange-600"><%= booth.candidates.length %></div>
                    <div class="text-gray-600">Candidates</div>
                </div>
            </div>
        </div>

        <div class="grid lg:grid-cols-2 gap-8">
            <!-- Results Chart -->
            <div class="bg-white rounded-xl shadow-lg p-8">
                <h3 class="text-xl font-bold text-gray-900 mb-6 text-center">Vote Distribution</h3>
                <div class="relative h-80">
                    <canvas id="resultsChart"></canvas>
                </div>
            </div>

            <!-- Detailed Results -->
            <div class="bg-white rounded-xl shadow-lg p-8">
                <h3 class="text-xl font-bold text-gray-900 mb-6">Detailed Results</h3>
                <div class="space-y-4">
                    <% 
                    // Sort candidates by vote count (descending)
                    const sortedCandidates = booth.candidates.map((candidate, index) => ({
                        ...candidate,
                        originalIndex: index
                    })).sort((a, b) => b.voteCount - a.voteCount);
                    
                    sortedCandidates.forEach((candidate, rank) => { 
                        const percentage = totalVotes > 0 ? ((candidate.voteCount / totalVotes) * 100).toFixed(1) : 0;
                        const isWinner = rank === 0 && candidate.voteCount > 0;
                    %>
                        <div class="candidate-result <%= isWinner ? 'ring-2 ring-yellow-400' : '' %> p-4 border border-gray-200 rounded-lg">
                            <div class="flex items-center justify-between mb-2">
                                <div class="flex items-center">
                                    <% if (isWinner) { %>
                                        <svg class="w-6 h-6 text-yellow-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                                            <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                                        </svg>
                                    <% } else { %>
                                        <div class="w-8 h-8 bg-gray-200 rounded-full flex items-center justify-center mr-2">
                                            <span class="text-gray-600 font-semibold text-sm"><%= rank + 1 %></span>
                                        </div>
                                    <% } %>
                                    <div>
                                        <h4 class="font-semibold text-gray-900">
                                            <%= candidate.name %>
                                            <% if (isWinner) { %>
                                                <span class="text-yellow-600 text-sm font-medium ml-2">WINNER</span>
                                            <% } %>
                                        </h4>
                                        <% if (candidate.description) { %>
                                            <p class="text-sm text-gray-600"><%= candidate.description %></p>
                                        <% } %>
                                    </div>
                                </div>
                                <div class="text-right">
                                    <div class="text-2xl font-bold text-gray-900"><%= candidate.voteCount %></div>
                                    <div class="text-sm text-gray-600"><%= percentage %>%</div>
                                </div>
                            </div>
                            
                            <!-- Progress Bar -->
                            <div class="w-full bg-gray-200 rounded-full h-3 mt-3">
                                <div class="bg-indigo-600 h-3 rounded-full transition-all duration-500 ease-out" 
                                     style="width: <%= percentage %>%"></div>
                            </div>
                        </div>
                    <% }); %>
                </div>

                <% if (totalVotes === 0) { %>
                    <div class="text-center py-8 text-gray-500">
                        <svg class="w-16 h-16 mx-auto mb-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
                        </svg>
                        <p class="text-lg mb-2">No votes yet</p>
                        <p class="text-sm">Results will appear as members start voting</p>
                    </div>
                <% } %>
            </div>
        </div>

        <!-- Voting Status (for creators) -->
        <% if (isCreator) { %>
            <div class="bg-white rounded-xl shadow-lg p-8 mt-8">
                <h3 class="text-xl font-bold text-gray-900 mb-6">Voting Status</h3>
                <div class="grid md:grid-cols-2 gap-8">
                    <div>
                        <h4 class="font-semibold text-gray-700 mb-3">Members who voted (<%= booth.members.filter(m => m.hasVoted).length %>)</h4>
                        <div class="space-y-2 max-h-48 overflow-y-auto">
                            <% booth.members.filter(m => m.hasVoted).forEach(member => { %>
                                <div class="flex items-center p-2 bg-green-50 rounded-lg">
                                    <svg class="w-4 h-4 text-green-500 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                                    </svg>
                                    <span class="text-sm text-gray-900"><%= member.user.name %></span>
                                </div>
                            <% }); %>
                        </div>
                    </div>
                    <div>
                        <h4 class="font-semibold text-gray-700 mb-3">Members who haven't voted (<%= booth.members.filter(m => !m.hasVoted).length %>)</h4>
                        <div class="space-y-2 max-h-48 overflow-y-auto">
                            <% booth.members.filter(m => !m.hasVoted).forEach(member => { %>
                                <div class="flex items-center p-2 bg-yellow-50 rounded-lg">
                                    <svg class="w-4 h-4 text-yellow-500 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                    </svg>
                                    <span class="text-sm text-gray-900"><%= member.user.name %></span>
                                </div>
                            <% }); %>
                        </div>
                    </div>
                </div>
            </div>
        <% } %>

        <!-- Actions -->
        <div class="text-center mt-8">
            <a href="/booth/<%= booth._id %>" class="bg-indigo-600 text-white px-6 py-3 rounded-lg font-semibold hover:bg-indigo-700 transition-colors shadow-md mr-4">
                Back to Booth
            </a>
            <% if (isCreator) { %>
                <button onclick="window.print()" class="bg-gray-600 text-white px-6 py-3 rounded-lg font-semibold hover:bg-gray-700 transition-colors shadow-md">
                    Print Results
                </button>
            <% } %>
        </div>
    </div>

    <script>
        // Chart.js configuration
        const ctx = document.getElementById('resultsChart').getContext('2d');
        const chartData = <%= JSON.stringify(chartData) %>;
        
        // Generate colors for each candidate
        const colors = [
            '#3B82F6', '#EF4444', '#10B981', '#F59E0B', '#8B5CF6',
            '#06B6D4', '#F97316', '#84CC16', '#EC4899', '#6B7280'
        ];
        
        const backgroundColors = colors.slice(0, chartData.labels.length);
        const borderColors = backgroundColors.map(color => color);

        new Chart(ctx, {
            type: 'doughnut',
            data: {
                labels: chartData.labels,
                datasets: [{
                    data: chartData.data,
                    backgroundColor: backgroundColors,
                    borderColor: borderColors,
                    borderWidth: 2,
                    hoverOffset: 4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: {
                            padding: 20,
                            usePointStyle: true,
                            font: {
                                size: 12
                            }
                        }
                    },
                    tooltip: {
                        callbacks: {
                            label: function(context) {
                                const label = context.label || '';
                                const value = context.parsed;
                                const total = context.dataset.data.reduce((a, b) => a + b, 0);
                                const percentage = total > 0 ? ((value / total) * 100).toFixed(1) : 0;
                                return `${label}: ${value} votes (${percentage}%)`;
                            }
                        }
                    }
                },
                animation: {
                    animateScale: true,
                    animateRotate: true
                }
            }
        });

        // Add animations
        document.addEventListener('DOMContentLoaded', function() {
            // Animate progress bars
            const progressBars = document.querySelectorAll('.bg-indigo-600');
            progressBars.forEach((bar, index) => {
                const width = bar.style.width;
                bar.style.width = '0%';
                setTimeout(() => {
                    bar.style.width = width;
                }, 500 + (index * 100));
            });

            // Fade in cards
            const cards = document.querySelectorAll('.bg-white');
            cards.forEach((card, index) => {
                card.style.animationDelay = `${index * 0.1}s`;
                card.classList.add('animate-fade-in');
            });
        });

        // Auto-refresh results (every 30 seconds)
        <% if (isCreator) { %>
            setInterval(() => {
                window.location.reload();
            }, 30000);
        <% } %>
    </script>
</body>
</html>
