<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Results - <%= booth.name %> | VoteBooth</title>
    <link href="/public/css/tailwind.css" rel="stylesheet">
    
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2"></script>
    <link href="/public/css/animations.css" rel="stylesheet">
</head>
<body class="bg-gradient-to-br from-slate-50 via-purple-50 to-pink-50 min-h-screen font-sans">
    <!-- Navigation -->
    <nav class="bg-white/95 backdrop-blur-sm border-b border-slate-200 sticky top-0 z-50 shadow-sm">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-16">
                <!-- Logo & Back -->
                <div class="flex items-center space-x-4">
                    <a href="/booth/<%= booth._id %>" class="text-slate-600 hover:text-primary transition-colors p-2 rounded-lg hover:bg-slate-100">
                        <i class="fas fa-arrow-left text-lg"></i>
                    </a>
                    <div class="flex items-center">
                        <i class="fas fa-chart-pie text-2xl text-purple-600 mr-3"></i>
                        <div>
                            <h1 class="font-bold text-xl text-slate-800">Election Results</h1>
                            <p class="text-sm text-slate-500"><%= booth.name %></p>
                        </div>
                    </div>
                </div>
                
                <!-- Action Buttons -->
                <div class="flex items-center space-x-4">
                    <% if (isCreator) { %>
                        <a href="/booth/<%= booth._id %>/admin" class="bg-slate-600 text-white px-4 py-2 rounded-lg font-medium hover:bg-slate-700 transition-colors">
                            <i class="fas fa-cogs mr-2"></i>Admin Panel
                        </a>
                    <% } %>
                    <button onclick="exportResults()" class="bg-emerald-600 text-white px-4 py-2 rounded-lg font-medium hover:bg-emerald-700 transition-colors">
                        <i class="fas fa-download mr-2"></i>Export
                    </button>
                    <button onclick="shareResults()" class="bg-blue-600 text-white px-4 py-2 rounded-lg font-medium hover:bg-blue-700 transition-colors">
                        <i class="fas fa-share mr-2"></i>Share
                    </button>
                </div>
            </div>
        </div>
    </nav>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <!-- Results Header -->
        <div class="text-center mb-8">
            <div class="inline-flex items-center space-x-3 mb-4">
                <div class="w-16 h-16 bg-gradient-to-r from-purple-500 to-pink-500 rounded-full flex items-center justify-center">
                    <i class="fas fa-trophy text-2xl text-white"></i>
                </div>
                <div class="text-left">
                    <h2 class="text-3xl font-bold text-slate-900"><%= booth.name %></h2>
                    <p class="text-slate-600">Final Results • <%= totalVotes %> total votes</p>
                </div>
            </div>
            <div class="flex items-center justify-center space-x-8 text-sm text-slate-500">
                <span><i class="fas fa-users mr-1"></i>Eligible: <%= booth.members.length %></span>
                <span><i class="fas fa-vote-yea mr-1"></i>Voted: <%= totalVotes %></span>
                <span><i class="fas fa-chart-bar mr-1"></i>Turnout: <%= Math.round((totalVotes / Math.max(booth.members.length, 1)) * 100) %>%</span>
                <span><i class="fas fa-calendar mr-1"></i><%= new Date(booth.updatedAt).toLocaleString() %></span>
            </div>
        </div>

        <!-- Winner Announcement -->
        <% if (candidatesWithPercentage.length > 0) { %>
            <% const winner = candidatesWithPercentage.reduce((a, b) => a.voteCount > b.voteCount ? a : b) %>
            <% if (winner.voteCount > 0) { %>
                <div class="bg-gradient-to-r from-yellow-100 to-amber-100 border border-yellow-300 rounded-2xl p-8 mb-8 text-center">
                    <div class="flex items-center justify-center mb-4">
                        <div class="w-20 h-20 bg-gradient-to-r from-yellow-400 to-amber-500 rounded-full flex items-center justify-center mr-4">
                            <i class="fas fa-crown text-3xl text-white"></i>
                        </div>
                        <div class="text-left">
                            <h3 class="text-2xl font-bold text-amber-900 mb-1">🎉 Winner!</h3>
                            <p class="text-lg font-semibold text-amber-800"><%= winner.name %></p>
                            <p class="text-amber-700">
                                <%= winner.voteCount %> votes (<%= winner.percentage %>%)
                                <% if (winner.voteCount > (candidatesWithPercentage.find(c => c._id !== winner._id)?.voteCount || 0)) { %>
                                    • Won by <%= winner.voteCount - (candidatesWithPercentage.find(c => c._id !== winner._id)?.voteCount || 0) %> votes
                                <% } %>
                            </p>
                        </div>
                    </div>
                </div>
            <% } %>
        <% } %>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-8">
            <!-- Chart Visualization -->
            <div class="lg:col-span-2">
                <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
                    <div class="px-8 py-6 border-b border-slate-200">
                        <h3 class="text-xl font-bold text-slate-900">Vote Distribution</h3>
                        <p class="text-slate-600">Visual breakdown of all votes</p>
                    </div>
                    <div class="p-8">
                        <div class="flex justify-center mb-6">
                            <div class="space-x-4">
                                <button onclick="switchChart('pie')" id="pieBtn" class="px-4 py-2 rounded-lg font-medium bg-purple-600 text-white">
                                    <i class="fas fa-chart-pie mr-2"></i>Pie Chart
                                </button>
                                <button onclick="switchChart('bar')" id="barBtn" class="px-4 py-2 rounded-lg font-medium bg-slate-200 text-slate-700 hover:bg-slate-300 transition-colors">
                                    <i class="fas fa-chart-bar mr-2"></i>Bar Chart
                                </button>
                                <button onclick="switchChart('doughnut')" id="doughnutBtn" class="px-4 py-2 rounded-lg font-medium bg-slate-200 text-slate-700 hover:bg-slate-300 transition-colors">
                                    <i class="fas fa-circle mr-2"></i>Doughnut
                                </button>
                            </div>
                        </div>
                        <div class="relative" style="height: 400px;">
                            <canvas id="resultsChart"></canvas>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Detailed Results -->
            <div class="space-y-6">
                <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
                    <div class="px-6 py-4 border-b border-slate-200">
                        <h3 class="text-lg font-bold text-slate-900">Detailed Results</h3>
                    </div>
                    <div class="divide-y divide-slate-200">
                        <% candidatesWithPercentage.sort((a, b) => b.voteCount - a.voteCount).forEach((candidate, index) => { %>
                        <div class="px-6 py-4">
                            <div class="flex items-center space-x-3 mb-3">
                                <div class="flex-shrink-0 flex items-center space-x-2">
                                    <% if (index === 0 && candidate.voteCount > 0) { %>
                                        <i class="fas fa-crown text-yellow-500"></i>
                                    <% } else { %>
                                        <span class="w-6 h-6 bg-slate-200 text-slate-600 rounded-full flex items-center justify-center text-sm font-bold">
                                            <%= index + 1 %>
                                        </span>
                                    <% } %>
                                </div>
                                <div class="flex-1">
                                    <h4 class="font-semibold text-slate-900"><%= candidate.name %></h4>
                                    <p class="text-sm text-slate-500">
                                        <%= candidate.voteCount %> votes • <%= candidate.percentage %>%
                                    </p>
                                </div>
                            </div>
                            <div class="w-full bg-slate-200 rounded-full h-3">
                                <div class="h-3 rounded-full transition-all duration-1000 ease-out"
                                     style="width: <%= candidate.percentage %>%; background: linear-gradient(90deg, <%= ['#8B5CF6', '#EC4899', '#06B6D4', '#10B981', '#F59E0B', '#EF4444', '#6366F1', '#84CC16'][index % 8] %>, <%= ['#A855F7', '#F472B6', '#0891B2', '#059669', '#D97706', '#DC2626', '#4F46E5', '#65A30D'][index % 8] %>);">
                                </div>
                            </div>
                        </div>
                        <% }) %>
                    </div>
                </div>

                <!-- Statistics -->
                <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6">
                    <h3 class="text-lg font-bold text-slate-900 mb-4">Statistics</h3>
                    <div class="space-y-4">
                        <div class="flex justify-between items-center">
                            <span class="text-slate-600">Total Votes</span>
                            <span class="font-bold text-slate-900"><%= totalVotes %></span>
                        </div>
                        <div class="flex justify-between items-center">
                            <span class="text-slate-600">Eligible Voters</span>
                            <span class="font-bold text-slate-900"><%= booth.members.length %></span>
                        </div>
                        <div class="flex justify-between items-center">
                            <span class="text-slate-600">Turnout Rate</span>
                            <span class="font-bold text-emerald-600"><%= Math.round((totalVotes / Math.max(booth.members.length, 1)) * 100) %>%</span>
                        </div>
                        <div class="flex justify-between items-center">
                            <span class="text-slate-600">Candidates</span>
                            <span class="font-bold text-slate-900"><%= booth.candidates.length %></span>
                        </div>
                        <div class="flex justify-between items-center">
                            <span class="text-slate-600">Status</span>
                            <span class="px-2 py-1 text-xs font-medium rounded-full <%= booth.status === 'active' ? 'bg-emerald-100 text-emerald-800' : booth.status === 'ended' ? 'bg-red-100 text-red-800' : 'bg-gray-100 text-gray-800' %>">
                                <%= booth.status.charAt(0).toUpperCase() + booth.status.slice(1) %>
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Live Updates -->
        <% if (booth.status === 'active') { %>
        <div class="bg-blue-50 border border-blue-200 rounded-xl p-6 mb-8">
            <div class="flex items-center space-x-3">
                <div class="w-3 h-3 bg-blue-500 rounded-full animate-pulse"></div>
                <div>
                    <h4 class="font-semibold text-blue-900">Live Results</h4>
                    <p class="text-blue-700">These results are updated in real-time as votes come in.</p>
                </div>
            </div>
        </div>
        <% } %>

        <!-- Additional Analysis -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <!-- Vote Timeline (if available) -->
            <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
                <div class="px-6 py-4 border-b border-slate-200">
                    <h3 class="text-lg font-bold text-slate-900">Vote Timeline</h3>
                    <p class="text-sm text-slate-600">When votes were cast</p>
                </div>
                <div class="p-6">
                    <div class="relative">
                        <canvas id="timelineChart" style="height: 200px;"></canvas>
                    </div>
                </div>
            </div>

            <!-- Participation Analysis -->
            <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
                <div class="px-6 py-4 border-b border-slate-200">
                    <h3 class="text-lg font-bold text-slate-900">Participation</h3>
                    <p class="text-sm text-slate-600">Voting engagement breakdown</p>
                </div>
                <div class="p-6">
                    <div class="space-y-4">
                        <div class="flex items-center justify-between">
                            <span class="text-slate-600">Voted</span>
                            <div class="flex items-center space-x-2">
                                <div class="w-24 bg-slate-200 rounded-full h-2">
                                    <div class="h-2 bg-emerald-500 rounded-full transition-all duration-1000"
                                         style="width: <%= Math.round((totalVotes / Math.max(booth.members.length, 1)) * 100) %>%;"></div>
                                </div>
                                <span class="text-sm font-medium text-emerald-600"><%= totalVotes %></span>
                            </div>
                        </div>
                        <div class="flex items-center justify-between">
                            <span class="text-slate-600">Not Voted</span>
                            <div class="flex items-center space-x-2">
                                <div class="w-24 bg-slate-200 rounded-full h-2">
                                    <div class="h-2 bg-slate-400 rounded-full transition-all duration-1000"
                                         style="width: <%= Math.round(((booth.members.length - totalVotes) / Math.max(booth.members.length, 1)) * 100) %>%;"></div>
                                </div>
                                <span class="text-sm font-medium text-slate-600"><%= booth.members.length - totalVotes %></span>
                            </div>
                        </div>
                    </div>
                    
                    <div class="mt-6 pt-6 border-t border-slate-200">
                        <div class="relative w-32 h-32 mx-auto">
                            <canvas id="participationChart"></canvas>
                            <div class="absolute inset-0 flex items-center justify-center">
                                <div class="text-center">
                                    <div class="text-2xl font-bold text-slate-900"><%= Math.round((totalVotes / Math.max(booth.members.length, 1)) * 100) %>%</div>
                                    <div class="text-xs text-slate-500">Turnout</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Share Modal -->
    <div id="shareModal" class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 opacity-0 invisible transition-all duration-300">
        <div class="bg-white rounded-2xl p-8 max-w-md mx-4 transform scale-95 transition-transform duration-300">
            <div class="text-center mb-6">
                <i class="fas fa-share text-4xl text-blue-600 mb-4"></i>
                <h3 class="text-xl font-bold text-slate-900">Share Results</h3>
                <p class="text-slate-600">Share these election results with others</p>
            </div>
            
            <div class="space-y-4">
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-2">Results URL</label>
                    <div class="flex items-center space-x-2">
                        <input type="text" id="shareUrl" readonly 
                               value="<%= process.env.BASE_URL || 'http://localhost:3000' %>/booth/<%= booth._id %>/results"
                               class="flex-1 px-3 py-2 border border-slate-300 rounded-lg bg-slate-50 text-sm">
                        <button onclick="copyShareUrl()" class="bg-blue-600 text-white px-3 py-2 rounded-lg hover:bg-blue-700 transition-colors">
                            <i class="fas fa-copy"></i>
                        </button>
                    </div>
                </div>
                
                <div class="flex space-x-2">
                    <button onclick="shareViaEmail()" class="flex-1 bg-slate-100 text-slate-700 px-4 py-3 rounded-lg hover:bg-slate-200 transition-colors">
                        <i class="fas fa-envelope mr-2"></i>Email
                    </button>
                    <button onclick="shareViaTwitter()" class="flex-1 bg-blue-500 text-white px-4 py-3 rounded-lg hover:bg-blue-600 transition-colors">
                        <i class="fab fa-twitter mr-2"></i>Twitter
                    </button>
                </div>
            </div>
            
            <button onclick="closeShareModal()" class="w-full mt-6 bg-slate-600 text-white px-4 py-3 rounded-lg hover:bg-slate-700 transition-colors">
                Close
            </button>
        </div>
    </div>

    <script>
        let currentChart = null;
        let currentChartType = 'pie';
        
        // Chart data from server
        const chartData = <%- chartData %>;
        const candidates = <%- JSON.stringify(candidatesWithPercentage) %>;
        
        // Chart colors
        const colors = [
            'rgba(139, 92, 246, 0.8)',  // Purple
            'rgba(236, 72, 153, 0.8)',  // Pink
            'rgba(6, 182, 212, 0.8)',   // Cyan
            'rgba(16, 185, 129, 0.8)',  // Emerald
            'rgba(245, 158, 11, 0.8)',  // Amber
            'rgba(239, 68, 68, 0.8)',   // Red
            'rgba(99, 102, 241, 0.8)',  // Indigo
            'rgba(132, 204, 22, 0.8)'   // Lime
        ];

        // Initialize charts on page load
        document.addEventListener('DOMContentLoaded', function() {
            initializeChart();
            initializeParticipationChart();
            initializeTimelineChart();
            
            // Auto-refresh if voting is active
            <% if (booth.status === 'active') { %>
            setInterval(refreshResults, 30000); // Refresh every 30 seconds
            <% } %>
        });

        function initializeChart() {
            const ctx = document.getElementById('resultsChart').getContext('2d');
            
            if (currentChart) {
                currentChart.destroy();
            }

            const config = {
                type: currentChartType,
                data: {
                    labels: chartData.labels,
                    datasets: [{
                        data: chartData.data,
                        backgroundColor: colors,
                        borderColor: colors.map(color => color.replace('0.8', '1')),
                        borderWidth: 2
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: currentChartType === 'bar' ? 'top' : 'right',
                            labels: {
                                usePointStyle: true,
                                padding: 15
                            }
                        },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    const total = context.dataset.data.reduce((a, b) => a + b, 0);
                                    const percentage = Math.round((context.parsed / total) * 100);
                                    return `${context.label}: ${context.parsed} votes (${percentage}%)`;
                                }
                            }
                        }
                    },
                    scales: currentChartType === 'bar' ? {
                        y: {
                            beginAtZero: true,
                            ticks: {
                                stepSize: 1
                            }
                        }
                    } : {}
                }
            };

            currentChart = new Chart(ctx, config);
        }

        function switchChart(type) {
            currentChartType = type;
            
            // Update button states
            document.querySelectorAll('[id$="Btn"]').forEach(btn => {
                btn.className = 'px-4 py-2 rounded-lg font-medium bg-slate-200 text-slate-700 hover:bg-slate-300 transition-colors';
            });
            document.getElementById(type + 'Btn').className = 'px-4 py-2 rounded-lg font-medium bg-purple-600 text-white';
            
            initializeChart();
        }

        function initializeParticipationChart() {
            const ctx = document.getElementById('participationChart').getContext('2d');
            
            new Chart(ctx, {
                type: 'doughnut',
                data: {
                    labels: ['Voted', 'Not Voted'],
                    datasets: [{
                        data: [<%= totalVotes %>, <%= booth.members.length - totalVotes %>],
                        backgroundColor: ['rgba(16, 185, 129, 0.8)', 'rgba(148, 163, 184, 0.3)'],
                        borderColor: ['rgba(16, 185, 129, 1)', 'rgba(148, 163, 184, 1)'],
                        borderWidth: 2,
                        cutout: '70%'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            display: false
                        },
                        tooltip: {
                            enabled: false
                        }
                    }
                }
            });
        }

        function initializeTimelineChart() {
            const ctx = document.getElementById('timelineChart').getContext('2d');
            
            // Generate sample timeline data (in real app, this would come from server)
            const hours = [];
            const voteCounts = [];
            for (let i = 0; i < 24; i++) {
                hours.push(i + ':00');
                voteCounts.push(Math.floor(Math.random() * 10));
            }
            
            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: hours,
                    datasets: [{
                        label: 'Votes per Hour',
                        data: voteCounts,
                        borderColor: 'rgba(99, 102, 241, 1)',
                        backgroundColor: 'rgba(99, 102, 241, 0.1)',
                        borderWidth: 2,
                        fill: true,
                        tension: 0.4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            display: false
                        }
                    },
                    scales: {
                        x: {
                            display: false
                        },
                        y: {
                            beginAtZero: true,
                            ticks: {
                                stepSize: 1
                            }
                        }
                    }
                }
            });
        }

        function exportResults() {
            const exportData = {
                booth: {
                    name: '<%= booth.name %>',
                    description: '<%= booth.description %>',
                    status: '<%= booth.status %>'
                },
                results: candidates,
                statistics: {
                    totalVotes: <%= totalVotes %>,
                    eligibleVoters: <%= booth.members.length %>,
                    turnoutRate: <%= Math.round((totalVotes / Math.max(booth.members.length, 1)) * 100) %>
                },
                exportedAt: new Date().toISOString()
            };
            
            const blob = new Blob([JSON.stringify(exportData, null, 2)], { type: 'application/json' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `${encodeURIComponent('<%= booth.name %>')}_results.json`;
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            URL.revokeObjectURL(url);
        }

        function shareResults() {
            document.getElementById('shareModal').classList.remove('opacity-0', 'invisible');
            document.getElementById('shareModal').querySelector('.bg-white').classList.remove('scale-95');
            document.getElementById('shareModal').querySelector('.bg-white').classList.add('scale-100');
        }

        function closeShareModal() {
            document.getElementById('shareModal').classList.add('opacity-0', 'invisible');
            document.getElementById('shareModal').querySelector('.bg-white').classList.remove('scale-100');
            document.getElementById('shareModal').querySelector('.bg-white').classList.add('scale-95');
        }

        function copyShareUrl() {
            const input = document.getElementById('shareUrl');
            input.select();
            document.execCommand('copy');
            
            // Show feedback
            const button = event.target.closest('button');
            const originalHTML = button.innerHTML;
            button.innerHTML = '<i class="fas fa-check"></i>';
            setTimeout(() => {
                button.innerHTML = originalHTML;
            }, 2000);
        }

        function shareViaEmail() {
            const subject = encodeURIComponent(`Results: <%= booth.name %>`);
            const body = encodeURIComponent(`Check out the results for "<%= booth.name %>": ${document.getElementById('shareUrl').value}`);
            window.open(`mailto:?subject=${subject}&body=${body}`);
        }

        function shareViaTwitter() {
            const text = encodeURIComponent(`Check out the election results for "<%= booth.name %>" - <%= totalVotes %> votes cast!`);
            const url = encodeURIComponent(document.getElementById('shareUrl').value);
            window.open(`https://twitter.com/intent/tweet?text=${text}&url=${url}`);
        }

        function refreshResults() {
            // In a real application, this would fetch updated results via AJAX
            location.reload();
        }

        // Close modal when clicking outside
        document.getElementById('shareModal').addEventListener('click', function(e) {
            if (e.target === this) {
                closeShareModal();
            }
        });
    </script>
</body>
</html>