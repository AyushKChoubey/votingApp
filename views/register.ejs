<!DOCTYPE html>
<html lang="en">

<head>
    <!-- Previous: <link href="/css/output.css" rel="stylesheet"> -->
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register - Voting App</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/animations.css">
</head>

<body class="min-h-screen bg-gradient-to-tr from-pink-400 via-yellow-300 to-indigo-500 flex items-center justify-center text-gray-900">
        <div class="w-full max-w-lg mx-auto p-10 rounded-3xl shadow-2xl bg-white/80 backdrop-blur-lg mt-10 mb-6 animate-fade-in">
        <h2 class="text-3xl font-extrabold text-pink-600 mb-6 text-center drop-shadow-lg">Create Account</h2>
        
        <!-- Error/Success Messages -->
        <% if (typeof error !== 'undefined' && error) { %>
            <div class="mb-4 p-3 bg-red-100 border border-red-400 text-red-700 rounded">
                <%= error %>
            </div>
        <% } %>
        <% if (typeof success !== 'undefined' && success) { %>
            <div class="mb-4 p-3 bg-green-100 border border-green-400 text-green-700 rounded">
                <%= success %>
            </div>
        <% } %>
        
        <form method="POST" action="/user/register" class="space-y-4">
            <div>
                <label for="name" class="block text-sm font-medium text-pink-700 mb-1">Full Name *</label>
                <input type="text" id="name" name="name" placeholder="Enter your full name" 
                       class="w-full px-4 py-2 border rounded focus:outline-none focus:ring focus:ring-pink-400 bg-white/90 text-gray-900" required>
            </div>
            
            <div>
                <label for="email" class="block text-sm font-medium text-pink-700 mb-1">Email Address *</label>
                <input type="email" id="email" name="email" placeholder="Enter your email address" 
                       class="w-full px-4 py-2 border rounded focus:outline-none focus:ring focus:ring-indigo-400 bg-white/90 text-gray-900" required>
            </div>
            
            <div>
                <label for="password" class="block text-sm font-medium text-pink-700 mb-1">Password *</label>
                <input type="password" id="password" name="password" placeholder="Create a strong password" 
                       class="w-full px-4 py-2 border rounded focus:outline-none focus:ring focus:ring-pink-400 bg-white/90 text-gray-900" 
                       required minlength="6">
            </div>
            
            <div>
                <label for="confirmPassword" class="block text-sm font-medium text-pink-700 mb-1">Confirm Password *</label>
                <input type="password" id="confirmPassword" name="confirmPassword" placeholder="Confirm your password" 
                       class="w-full px-4 py-2 border rounded focus:outline-none focus:ring focus:ring-pink-400 bg-white/90 text-gray-900" 
                       required minlength="6">
            </div>
            
            <!-- Optional Profile Fields -->
            <div>
                <label for="organization" class="block text-sm font-medium text-pink-700 mb-1">Organization (Optional)</label>
                <input type="text" id="organization" name="profile[organization]" placeholder="Your organization or school" 
                       class="w-full px-4 py-2 border rounded focus:outline-none focus:ring focus:ring-yellow-400 bg-white/90 text-gray-900">
            </div>
            
            <div>
                <label for="bio" class="block text-sm font-medium text-pink-700 mb-1">Bio (Optional)</label>
                <textarea id="bio" name="profile[bio]" rows="2" placeholder="Tell us about yourself" 
                          class="w-full px-4 py-2 border rounded focus:outline-none focus:ring focus:ring-yellow-400 bg-white/90 text-gray-900 resize-none"></textarea>
            </div>
            
            <div>
                <label for="role" class="block text-sm font-medium text-pink-700 mb-1">Account Type</label>
                <select id="role" name="role" class="w-full px-4 py-2 border rounded focus:outline-none focus:ring focus:ring-yellow-400 bg-white/90 text-gray-900">
                    <option value="voter" selected>Voter (Join and vote in booths)</option>
                    <option value="admin">Admin (Create and manage booths)</option>
                </select>
            </div>
            
            <button type="submit" class="w-full py-3 bg-pink-600 text-white rounded-lg font-semibold shadow hover:bg-pink-700 focus:ring-4 focus:ring-pink-300 transition-all duration-300">
                Create Account
            </button>
        </form>
        
        <div class="mt-6 text-center">
            <p class="text-sm text-gray-600 mb-3">Already have an account?</p>
            <a href="/user/login" class="inline-block px-6 py-2 bg-indigo-500 text-white rounded-lg hover:bg-indigo-600 font-semibold transition-colors">
                Login Here
            </a>
        </div>
        
        <div class="mt-4 text-center">
            <a href="/" class="text-pink-600 hover:text-pink-800 text-sm">← Back to Home</a>
        </div>
    </div>
    
    <script>
        // Password confirmation validation
        document.getElementById('confirmPassword').addEventListener('input', function() {
            const password = document.getElementById('password').value;
            const confirmPassword = this.value;
            
            if (password !== confirmPassword) {
                this.setCustomValidity('Passwords do not match');
                this.classList.add('border-red-500');
            } else {
                this.setCustomValidity('');
                this.classList.remove('border-red-500');
            }
        });
    </script>
</body>

</html>