<!DOCTYPE html>
<html lang="en">

<head>
    <!-- Previous: <link href="/css/output.css" rel="stylesheet"> -->
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register - Voting App</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/animations.css">
</head>

<body class="min-h-screen bg-gradient-to-tr from-pink-400 via-yellow-300 to-indigo-500 flex items-center justify-center text-gray-900">
        <div class="w-full max-w-lg mx-auto p-10 rounded-3xl shadow-2xl bg-white/80 backdrop-blur-lg mt-10 mb-6 animate-fade-in">
        <h2 class="text-3xl font-extrabold text-pink-600 mb-6 text-center drop-shadow-lg">Register</h2>
        <% if (typeof error !== 'undefined') { %>
            <div class="mb-4 p-3 bg-red-100 text-red-700 rounded"><%= error %></div>
        <% } %>
        <% if (typeof success !== 'undefined') { %>
            <div class="mb-4 p-3 bg-green-100 text-green-700 rounded"><%= success %></div>
        <% } %>
        <form method="POST" action="/user/register" class="space-y-4">
            <input type="text" name="name" placeholder="Full Name" class="w-full px-4 py-2 border rounded focus:outline-none focus:ring focus:ring-pink-400 bg-white/80 text-gray-900" required>
            <input type="number" name="age" placeholder="Age" class="w-full px-4 py-2 border rounded focus:outline-none focus:ring focus:ring-yellow-400 bg-white/80 text-gray-900" required>
            <input type="email" name="email" placeholder="Email" class="w-full px-4 py-2 border rounded focus:outline-none focus:ring focus:ring-indigo-400 bg-white/80 text-gray-900">
            <input type="text" name="mobile" placeholder="Mobile" class="w-full px-4 py-2 border rounded focus:outline-none focus:ring focus:ring-pink-400 bg-white/80 text-gray-900">
            <input type="text" name="address" placeholder="Address" class="w-full px-4 py-2 border rounded focus:outline-none focus:ring focus:ring-yellow-400 bg-white/80 text-gray-900" required>
            <input type="text" name="aadharCardNumber" placeholder="Aadhar Card Number (12 digits)" class="w-full px-4 py-2 border rounded focus:outline-none focus:ring focus:ring-indigo-400 bg-white/80 text-gray-900" required maxlength="12" pattern="\d{12}">
            <input type="password" name="password" placeholder="Password" class="w-full px-4 py-2 border rounded focus:outline-none focus:ring focus:ring-pink-400 bg-white/80 text-gray-900" required>
            <select name="role" class="w-full px-4 py-2 border rounded focus:outline-none focus:ring focus:ring-yellow-400 bg-white/80 text-gray-900">
                <option value="voter" selected>Voter</option>
                <option value="admin">Admin</option>
            </select>
            <button type="submit" class="w-full py-2 bg-pink-600 text-white rounded-lg font-semibold shadow hover:bg-yellow-400 hover:text-indigo-700 focus:ring-4 focus:ring-pink-300 transition-all duration-300 animate-bounce-once">Register</button>
        </form>
        <p class="mt-6 text-center text-sm text-gray-700">Already have an account?
            <a href="/user/login" class="inline-block px-4 py-2 ml-2 bg-white text-pink-600 rounded hover:bg-pink-100 font-semibold transition">Login</a>
        </p>
    </div>
</body>

</html>