<!DOCTYPE html>
<html lang="en">
<head>
  <!-- Previous: <link href="/css/output.css" rel="stylesheet"> -->
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Candidates - Voting App</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/css/animations.css">
</head>
<body class="min-h-screen bg-gradient-to-tr from-yellow-300 via-pink-400 to-indigo-500 flex items-center justify-center text-gray-900">
  <div class="w-full max-w-5xl mx-auto p-10 rounded-3xl shadow-2xl bg-white/80 backdrop-blur-lg mt-10 mb-6">
    <h1 class="text-3xl font-extrabold text-indigo-700 mb-8 text-center drop-shadow-lg">Candidates</h1>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      <% candidates.forEach(function(candidate) { %>
  <div class="bg-white/90 p-8 rounded-2xl shadow flex flex-col items-center gap-2 animate-fade-in">
          <h2 class="text-xl font-bold text-pink-600 mb-2"><%= candidate.name %></h2>
          <p class="mb-2 text-gray-700"><span class="font-semibold">Party:</span> <%= candidate.party %></p>
          <p class="mb-4 text-gray-700"><span class="font-semibold">Votes:</span> <span class="font-bold"><%= candidate.voteCount || candidate.votes %></span></p>
          <form method="POST" action="/candidate/vote/<%= candidate._id %>">
            <button type="submit" class="px-6 py-2 bg-indigo-600 text-white rounded-lg font-semibold shadow hover:bg-yellow-400 hover:text-indigo-700 focus:ring-4 focus:ring-indigo-300 transition-all duration-300 animate-bounce-once">Vote</button>
          </form>
        </div>
      <% }) %>
    </div>
  </div>
</body>
</html>
