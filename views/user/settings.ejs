<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Account Settings - VoteBooth</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="/public/css/tailwind.css" rel="stylesheet">
    
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
</head>
<body class="bg-gradient-to-br from-blue-50 to-indigo-100 min-h-screen">
    <!-- Navigation -->
    <nav class="bg-white shadow-lg fixed w-full z-50 top-0">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16">
                <div class="flex items-center">
                    <div class="flex-shrink-0 flex items-center">
                        <i class="fas fa-vote-yea text-3xl text-primary mr-2"></i>
                        <a href="/" class="font-bold text-2xl text-gray-800 hover:text-primary transition-colors">VoteBooth</a>
                    </div>
                </div>
                <div class="hidden md:flex items-center space-x-4">
                    <a href="/about" class="text-gray-700 hover:text-primary px-3 py-2 rounded-md text-sm font-medium transition-colors">About</a>
                    <a href="/features" class="text-gray-700 hover:text-primary px-3 py-2 rounded-md text-sm font-medium transition-colors">Features</a>
                    <a href="/pricing" class="text-gray-700 hover:text-primary px-3 py-2 rounded-md text-sm font-medium transition-colors">Pricing</a>
                    <a href="/contact" class="text-gray-700 hover:text-primary px-3 py-2 rounded-md text-sm font-medium transition-colors">Contact</a>
                    <a href="/help" class="text-gray-700 hover:text-primary px-3 py-2 rounded-md text-sm font-medium transition-colors">Help</a>
                    <% if (user) { %>
                        <a href="/booth/dashboard" class="text-gray-700 hover:text-primary px-3 py-2 rounded-md text-sm font-medium transition-colors">Dashboard</a>
                        <a href="/user/settings" class="bg-primary text-white px-4 py-2 rounded-md text-sm font-medium hover:bg-blue-700 transition-colors">Settings</a>
                        <a href="/user/logout" class="text-gray-700 hover:text-red-600 px-3 py-2 rounded-md text-sm font-medium transition-colors">Logout</a>
                    <% } else { %>
                        <a href="/user/login" class="text-primary hover:text-blue-700 px-3 py-2 rounded-md text-sm font-medium transition-colors">Login</a>
                        <a href="/user/register" class="bg-primary text-white px-4 py-2 rounded-md text-sm font-medium hover:bg-blue-700 transition-colors">Sign Up</a>
                    <% } %>
                </div>
                <!-- Mobile menu button -->
                <div class="md:hidden flex items-center">
                    <button type="button" class="text-gray-700 hover:text-primary focus:outline-none focus:text-primary" onclick="toggleMobileMenu()">
                        <i class="fas fa-bars text-xl"></i>
                    </button>
                </div>
            </div>
        </div>
        <!-- Mobile menu -->
        <div id="mobile-menu" class="hidden md:hidden">
            <div class="px-2 pt-2 pb-3 space-y-1 sm:px-3 bg-white border-t">
                <a href="/about" class="text-gray-700 hover:text-primary block px-3 py-2 rounded-md text-base font-medium">About</a>
                <a href="/features" class="text-gray-700 hover:text-primary block px-3 py-2 rounded-md text-base font-medium">Features</a>
                <a href="/pricing" class="text-gray-700 hover:text-primary block px-3 py-2 rounded-md text-base font-medium">Pricing</a>
                <a href="/contact" class="text-gray-700 hover:text-primary block px-3 py-2 rounded-md text-base font-medium">Contact</a>
                <a href="/help" class="text-gray-700 hover:text-primary block px-3 py-2 rounded-md text-base font-medium">Help</a>
                <% if (user) { %>
                    <a href="/booth/dashboard" class="text-gray-700 hover:text-primary block px-3 py-2 rounded-md text-base font-medium">Dashboard</a>
                    <a href="/user/settings" class="bg-primary text-white block px-3 py-2 rounded-md text-base font-medium">Settings</a>
                    <a href="/user/logout" class="text-gray-700 hover:text-red-600 block px-3 py-2 rounded-md text-base font-medium">Logout</a>
                <% } else { %>
                    <a href="/user/login" class="text-primary block px-3 py-2 rounded-md text-base font-medium">Login</a>
                    <a href="/user/register" class="bg-primary text-white block px-3 py-2 rounded-md text-base font-medium">Sign Up</a>
                <% } %>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="pt-20 pb-16">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
            <!-- Header Section -->
            <div class="text-center mb-8">
                <div class="inline-flex items-center justify-center w-16 h-16 bg-primary/10 rounded-full mb-6">
                    <i class="fas fa-user-cog text-3xl text-primary"></i>
                </div>
                <h1 class="text-4xl font-bold text-gray-900 mb-4">Account Settings</h1>
                <p class="text-xl text-gray-600">
                    Manage your profile, security, and preferences
                </p>
            </div>

            <!-- Alert Messages -->
            <% if (error) { %>
                <div class="bg-red-50 border border-red-200 rounded-md p-4 mb-6">
                    <div class="flex">
                        <div class="flex-shrink-0">
                            <i class="fas fa-exclamation-circle text-red-400"></i>
                        </div>
                        <div class="ml-3">
                            <p class="text-sm text-red-800"><%= error %></p>
                        </div>
                    </div>
                </div>
            <% } %>

            <% if (success) { %>
                <div class="bg-green-50 border border-green-200 rounded-md p-4 mb-6">
                    <div class="flex">
                        <div class="flex-shrink-0">
                            <i class="fas fa-check-circle text-green-400"></i>
                        </div>
                        <div class="ml-3">
                            <p class="text-sm text-green-800"><%= success %></p>
                        </div>
                    </div>
                </div>
            <% } %>

            <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                <!-- Sidebar Navigation -->
                <div class="lg:col-span-1">
                    <nav class="bg-white rounded-lg shadow-md p-6 sticky top-24">
                        <ul class="space-y-2">
                            <li>
                                <button onclick="showSection('profile')" 
                                        class="settings-nav-btn w-full text-left px-4 py-3 rounded-lg text-gray-700 hover:bg-gray-100 transition-colors flex items-center active"
                                        data-section="profile">
                                    <i class="fas fa-user mr-3"></i>
                                    Profile Information
                                </button>
                            </li>
                            <li>
                                <button onclick="showSection('security')" 
                                        class="settings-nav-btn w-full text-left px-4 py-3 rounded-lg text-gray-700 hover:bg-gray-100 transition-colors flex items-center"
                                        data-section="security">
                                    <i class="fas fa-shield-alt mr-3"></i>
                                    Security
                                </button>
                            </li>
                            <li>
                                <button onclick="showSection('preferences')" 
                                        class="settings-nav-btn w-full text-left px-4 py-3 rounded-lg text-gray-700 hover:bg-gray-100 transition-colors flex items-center"
                                        data-section="preferences">
                                    <i class="fas fa-cog mr-3"></i>
                                    Preferences
                                </button>
                            </li>
                            <li>
                                <button onclick="showSection('data')" 
                                        class="settings-nav-btn w-full text-left px-4 py-3 rounded-lg text-gray-700 hover:bg-gray-100 transition-colors flex items-center"
                                        data-section="data">
                                    <i class="fas fa-database mr-3"></i>
                                    Data & Privacy
                                </button>
                            </li>
                        </ul>
                    </nav>
                </div>

                <!-- Main Content Area -->
                <div class="lg:col-span-2">
                    <!-- Profile Section -->
                    <div id="profile-section" class="settings-section bg-white rounded-lg shadow-md p-8">
                        <h2 class="text-2xl font-bold text-gray-900 mb-6 flex items-center">
                            <i class="fas fa-user text-primary mr-3"></i>
                            Profile Information
                        </h2>
                        
                        <form action="/user/api/profile" method="PUT" class="space-y-6">
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div>
                                    <label for="name" class="block text-sm font-medium text-gray-700 mb-2">Full Name</label>
                                    <input type="text" 
                                           id="name" 
                                           name="name" 
                                           value="<%= user.name %>"
                                           class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary"
                                           required>
                                </div>
                                <div>
                                    <label for="email" class="block text-sm font-medium text-gray-700 mb-2">Email Address</label>
                                    <input type="email" 
                                           id="email" 
                                           name="email" 
                                           value="<%= user.email %>"
                                           class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary"
                                           required>
                                </div>
                            </div>
                            
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div>
                                    <label class="block text-sm font-medium text-gray-700 mb-2">Account Type</label>
                                    <div class="px-3 py-2 bg-gray-50 border border-gray-300 rounded-md text-gray-600">
                                        <%= user.role.charAt(0).toUpperCase() + user.role.slice(1) %>
                                    </div>
                                </div>
                                <div>
                                    <label class="block text-sm font-medium text-gray-700 mb-2">Member Since</label>
                                    <div class="px-3 py-2 bg-gray-50 border border-gray-300 rounded-md text-gray-600">
                                        <%= new Date(user.createdAt).toLocaleDateString() %>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="flex justify-end">
                                <button type="submit" 
                                        class="bg-primary text-white px-6 py-2 rounded-md hover:bg-blue-700 transition-colors">
                                    <i class="fas fa-save mr-2"></i>
                                    Save Changes
                                </button>
                            </div>
                        </form>
                    </div>

                    <!-- Security Section -->
                    <div id="security-section" class="settings-section bg-white rounded-lg shadow-md p-8 hidden">
                        <h2 class="text-2xl font-bold text-gray-900 mb-6 flex items-center">
                            <i class="fas fa-shield-alt text-primary mr-3"></i>
                            Security Settings
                        </h2>
                        
                        <!-- Change Password -->
                        <div class="mb-8">
                            <h3 class="text-lg font-semibold text-gray-900 mb-4">Change Password</h3>
                            <form action="/user/api/password" method="PUT" class="space-y-4">
                                <div>
                                    <label for="currentPassword" class="block text-sm font-medium text-gray-700 mb-2">Current Password</label>
                                    <input type="password" 
                                           id="currentPassword" 
                                           name="currentPassword" 
                                           class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary"
                                           required>
                                </div>
                                <div>
                                    <label for="newPassword" class="block text-sm font-medium text-gray-700 mb-2">New Password</label>
                                    <input type="password" 
                                           id="newPassword" 
                                           name="newPassword" 
                                           class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary"
                                           required>
                                    <p class="text-xs text-gray-500 mt-1">Minimum 8 characters with uppercase, lowercase, and number</p>
                                </div>
                                <div>
                                    <label for="confirmPassword" class="block text-sm font-medium text-gray-700 mb-2">Confirm New Password</label>
                                    <input type="password" 
                                           id="confirmPassword" 
                                           name="confirmPassword" 
                                           class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary"
                                           required>
                                </div>
                                <div class="flex justify-end">
                                    <button type="submit" 
                                            class="bg-primary text-white px-6 py-2 rounded-md hover:bg-blue-700 transition-colors">
                                        <i class="fas fa-key mr-2"></i>
                                        Update Password
                                    </button>
                                </div>
                            </form>
                        </div>

                        <!-- Active Sessions -->
                        <div class="border-t pt-8">
                            <h3 class="text-lg font-semibold text-gray-900 mb-4">Active Sessions</h3>
                            <div class="space-y-3">
                                <div class="flex items-center justify-between p-4 bg-gray-50 rounded-lg">
                                    <div class="flex items-center">
                                        <i class="fas fa-desktop text-gray-400 mr-3"></i>
                                        <div>
                                            <p class="font-medium text-gray-900">Current Session</p>
                                            <p class="text-sm text-gray-500">Active now</p>
                                        </div>
                                    </div>
                                    <span class="text-sm text-green-600 font-medium">Current</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Preferences Section -->
                    <div id="preferences-section" class="settings-section bg-white rounded-lg shadow-md p-8 hidden">
                        <h2 class="text-2xl font-bold text-gray-900 mb-6 flex items-center">
                            <i class="fas fa-cog text-primary mr-3"></i>
                            Preferences
                        </h2>
                        
                        <form action="/user/api/preferences" method="PUT" class="space-y-6">
                            <!-- Email Notifications -->
                            <div>
                                <h3 class="text-lg font-semibold text-gray-900 mb-4">Email Notifications</h3>
                                <div class="space-y-3">
                                    <div class="flex items-center">
                                        <input type="checkbox" 
                                               id="emailVoteReminders" 
                                               name="emailVoteReminders" 
                                               class="h-4 w-4 text-primary focus:ring-primary border-gray-300 rounded"
                                               <%= user.preferences?.emailVoteReminders !== false ? 'checked' : '' %>>
                                        <label for="emailVoteReminders" class="ml-2 text-sm text-gray-700">
                                            Vote reminders and deadlines
                                        </label>
                                    </div>
                                    <div class="flex items-center">
                                        <input type="checkbox" 
                                               id="emailBoothInvites" 
                                               name="emailBoothInvites" 
                                               class="h-4 w-4 text-primary focus:ring-primary border-gray-300 rounded"
                                               <%= user.preferences?.emailBoothInvites !== false ? 'checked' : '' %>>
                                        <label for="emailBoothInvites" class="ml-2 text-sm text-gray-700">
                                            Booth invitations
                                        </label>
                                    </div>
                                    <div class="flex items-center">
                                        <input type="checkbox" 
                                               id="emailSystemUpdates" 
                                               name="emailSystemUpdates" 
                                               class="h-4 w-4 text-primary focus:ring-primary border-gray-300 rounded"
                                               <%= user.preferences?.emailSystemUpdates !== false ? 'checked' : '' %>>
                                        <label for="emailSystemUpdates" class="ml-2 text-sm text-gray-700">
                                            System updates and announcements
                                        </label>
                                    </div>
                                </div>
                            </div>

                            <!-- Privacy Settings -->
                            <div class="border-t pt-6">
                                <h3 class="text-lg font-semibold text-gray-900 mb-4">Privacy Settings</h3>
                                <div class="space-y-3">
                                    <div>
                                        <label for="defaultVotePrivacy" class="block text-sm font-medium text-gray-700 mb-2">
                                            Default Vote Privacy
                                        </label>
                                        <select id="defaultVotePrivacy" 
                                                name="defaultVotePrivacy" 
                                                class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary">
                                            <option value="private" <%= user.preferences?.defaultVotePrivacy === 'private' ? 'selected' : '' %>>Private (Only booth creators can see)</option>
                                            <option value="anonymous" <%= user.preferences?.defaultVotePrivacy === 'anonymous' ? 'selected' : '' %>>Anonymous (No connection to voter)</option>
                                            <option value="public" <%= user.preferences?.defaultVotePrivacy === 'public' ? 'selected' : '' %>>Public (All participants can see)</option>
                                            <option value="results-only" <%= user.preferences?.defaultVotePrivacy === 'results-only' ? 'selected' : '' %>>Results Only (Aggregate results only)</option>
                                        </select>
                                    </div>
                                </div>
                            </div>

                            <div class="flex justify-end">
                                <button type="submit" 
                                        class="bg-primary text-white px-6 py-2 rounded-md hover:bg-blue-700 transition-colors">
                                    <i class="fas fa-save mr-2"></i>
                                    Save Preferences
                                </button>
                            </div>
                        </form>
                    </div>

                    <!-- Data & Privacy Section -->
                    <div id="data-section" class="settings-section bg-white rounded-lg shadow-md p-8 hidden">
                        <h2 class="text-2xl font-bold text-gray-900 mb-6 flex items-center">
                            <i class="fas fa-database text-primary mr-3"></i>
                            Data & Privacy
                        </h2>
                        
                        <!-- Export Data -->
                        <div class="mb-8">
                            <h3 class="text-lg font-semibold text-gray-900 mb-4">Export Your Data</h3>
                            <p class="text-gray-600 mb-4">
                                Download a copy of your account data, voting history, and preferences.
                            </p>
                            <button class="bg-blue-600 text-white px-6 py-2 rounded-md hover:bg-blue-700 transition-colors">
                                <i class="fas fa-download mr-2"></i>
                                Export Data
                            </button>
                        </div>

                        <!-- Delete Account -->
                        <div class="border-t pt-8">
                            <h3 class="text-lg font-semibold text-red-600 mb-4">Delete Account</h3>
                            <p class="text-gray-600 mb-4">
                                Permanently delete your account and all associated data. This action cannot be undone.
                            </p>
                            <button onclick="showDeleteConfirmation()" 
                                    class="bg-red-600 text-white px-6 py-2 rounded-md hover:bg-red-700 transition-colors">
                                <i class="fas fa-trash-alt mr-2"></i>
                                Delete Account
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- Delete Confirmation Modal -->
    <div id="deleteModal" class="fixed inset-0 bg-gray-600 bg-opacity-50 hidden items-center justify-center z-50">
        <div class="bg-white rounded-lg shadow-xl max-w-md w-full mx-4">
            <div class="p-6">
                <div class="flex items-center mb-4">
                    <div class="bg-red-100 rounded-full p-3 mr-4">
                        <i class="fas fa-exclamation-triangle text-red-600 text-xl"></i>
                    </div>
                    <h3 class="text-lg font-semibold text-gray-900">Delete Account</h3>
                </div>
                <p class="text-gray-600 mb-6">
                    Are you sure you want to delete your account? This will permanently remove all your data, including voting history and booth memberships.
                </p>
                <div class="flex justify-end space-x-3">
                    <button onclick="hideDeleteConfirmation()" 
                            class="px-4 py-2 text-gray-700 bg-gray-200 rounded-md hover:bg-gray-300 transition-colors">
                        Cancel
                    </button>
                    <button onclick="deleteAccount()" 
                            class="px-4 py-2 bg-red-600 text-white rounded-md hover:bg-red-700 transition-colors">
                        Delete Account
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script>
        function toggleMobileMenu() {
            const menu = document.getElementById('mobile-menu');
            menu.classList.toggle('hidden');
        }

        function showSection(sectionName) {
            // Hide all sections
            document.querySelectorAll('.settings-section').forEach(section => {
                section.classList.add('hidden');
            });
            
            // Remove active class from all nav buttons
            document.querySelectorAll('.settings-nav-btn').forEach(btn => {
                btn.classList.remove('active', 'bg-primary', 'text-white');
                btn.classList.add('text-gray-700');
            });
            
            // Show selected section
            document.getElementById(sectionName + '-section').classList.remove('hidden');
            
            // Highlight active nav button
            const activeBtn = document.querySelector(`[data-section="${sectionName}"]`);
            activeBtn.classList.add('active', 'bg-primary', 'text-white');
            activeBtn.classList.remove('text-gray-700');
        }

        function showDeleteConfirmation() {
            document.getElementById('deleteModal').classList.remove('hidden');
            document.getElementById('deleteModal').classList.add('flex');
        }

        function hideDeleteConfirmation() {
            document.getElementById('deleteModal').classList.add('hidden');
            document.getElementById('deleteModal').classList.remove('flex');
        }

        function deleteAccount() {
            // Implement account deletion
            fetch('/user/api/account', {
                method: 'DELETE',
                headers: {
                    'Content-Type': 'application/json',
                },
            })
            .then(response => response.json())
            .then(data => {
                if (data.error) {
                    alert('Error: ' + data.error);
                } else {
                    alert('Account deleted successfully');
                    window.location.href = '/';
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('An error occurred while deleting your account');
            });
        }

        // Handle form submissions via AJAX
        document.querySelectorAll('form').forEach(form => {
            form.addEventListener('submit', async (e) => {
                e.preventDefault();
                
                const formData = new FormData(form);
                const data = Object.fromEntries(formData);
                
                try {
                    const response = await fetch(form.action, {
                        method: form.getAttribute('method') || 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                        },
                        body: JSON.stringify(data)
                    });
                    
                    const result = await response.json();
                    
                    if (result.error) {
                        showAlert(result.error, 'error');
                    } else {
                        showAlert(result.message || 'Settings updated successfully', 'success');
                    }
                } catch (error) {
                    console.error('Error:', error);
                    showAlert('An error occurred while saving your settings', 'error');
                }
            });
        });

        function showAlert(message, type) {
            // Remove existing alerts
            document.querySelectorAll('.alert').forEach(alert => alert.remove());
            
            const alertDiv = document.createElement('div');
            alertDiv.className = `alert fixed top-20 right-4 z-50 max-w-md p-4 rounded-md shadow-lg ${
                type === 'error' ? 'bg-red-50 border border-red-200 text-red-800' : 
                'bg-green-50 border border-green-200 text-green-800'
            }`;
            
            alertDiv.innerHTML = `
                <div class="flex">
                    <div class="flex-shrink-0">
                        <i class="fas ${type === 'error' ? 'fa-exclamation-circle text-red-400' : 'fa-check-circle text-green-400'}"></i>
                    </div>
                    <div class="ml-3">
                        <p class="text-sm">${message}</p>
                    </div>
                    <div class="ml-auto pl-3">
                        <button onclick="this.parentElement.parentElement.parentElement.remove()" 
                                class="text-gray-400 hover:text-gray-600">
                            <i class="fas fa-times"></i>
                        </button>
                    </div>
                </div>
            `;
            
            document.body.appendChild(alertDiv);
            
            // Auto-remove after 5 seconds
            setTimeout(() => {
                if (alertDiv.parentElement) {
                    alertDiv.remove();
                }
            }, 5000);
        }

        // Close mobile menu when clicking outside
        document.addEventListener('click', function(event) {
            const menu = document.getElementById('mobile-menu');
            const button = event.target.closest('button');
            
            if (!menu.contains(event.target) && !button) {
                menu.classList.add('hidden');
            }
        });
    </script>
</body>
</html>