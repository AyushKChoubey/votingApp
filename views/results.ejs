<!DOCTYPE html>
<html lang="en">
<head>
  <!-- Previous: <link href="/css/output.css" rel="stylesheet"> -->
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Results - Voting App</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/css/animations.css">
</head>
<body class="min-h-screen bg-gradient-to-tr from-indigo-500 via-green-400 to-yellow-300 flex items-center justify-center text-gray-900">
  <div class="w-full max-w-3xl mx-auto p-10 rounded-3xl shadow-2xl bg-white/80 backdrop-blur-lg mt-10 mb-6 animate-fade-in">
    <h1 class="text-3xl font-extrabold text-green-600 mb-8 text-center drop-shadow-lg">Voting Results</h1>
    <table class="min-w-full bg-white/90 rounded-xl shadow">
      <thead>
        <tr>
          <th class="py-3 px-6 border-b text-left text-indigo-700">Candidate</th>
          <th class="py-3 px-6 border-b text-left text-green-700">Votes</th>
        </tr>
      </thead>
      <tbody>
        <% candidates.forEach(function(candidate) { %>
          <tr class="hover:bg-green-100">
            <td class="py-3 px-6 border-b"><%= candidate.name %></td>
            <td class="py-3 px-6 border-b"><%= candidate.voteCount || candidate.votes %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</body>
</html>
