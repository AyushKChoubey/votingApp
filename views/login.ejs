<!DOCTYPE html>
<html lang="en">
<head>
  <!-- Previous: <link href="/css/output.css" rel="stylesheet"> -->
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login - Voting App</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/css/animations.css">
</head>
<body class="min-h-screen bg-gradient-to-tr from-indigo-500 via-pink-400 to-yellow-300 flex items-center justify-center text-gray-900">
  <div class="w-full max-w-xl p-12 bg-white/80 rounded-3xl shadow-2xl animate-fade-in">
    <h2 class="text-3xl font-extrabold text-indigo-700 mb-6 text-center drop-shadow-lg">Login to Voting App</h2>
    
    <!-- Error/Success Messages -->
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">
        <%= error %>
      </div>
    <% } %>
    <% if (typeof success !== 'undefined' && success) { %>
      <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4">
        <%= success %>
      </div>
    <% } %>
    
    <form method="POST" action="/user/login" class="space-y-4">
      <div>
        <label for="email" class="block text-sm font-medium text-indigo-700 mb-2">Email Address</label>
        <input type="email" id="email" name="email" placeholder="Enter your email" 
               class="w-full px-4 py-2 border rounded focus:outline-none focus:ring-4 focus:ring-indigo-400 bg-white/90 text-gray-900 transition-all duration-200" required>
      </div>
      <div>
        <label for="password" class="block text-sm font-medium text-indigo-700 mb-2">Password</label>
        <input type="password" id="password" name="password" placeholder="Enter your password" 
               class="w-full px-4 py-2 border rounded focus:outline-none focus:ring-4 focus:ring-pink-400 bg-white/90 text-gray-900 transition-all duration-200" required>
      </div>
      <button type="submit" class="w-full py-3 bg-indigo-600 text-white rounded-lg font-semibold shadow hover:bg-indigo-700 focus:ring-4 focus:ring-indigo-300 transition-all duration-300">
        Login
      </button>
    </form>
    
    <div class="mt-6 text-center">
      <p class="text-sm text-gray-600 mb-3">Don't have an account?</p>
      <a href="/user/register" class="inline-block px-6 py-2 bg-green-500 text-white rounded-lg hover:bg-green-600 font-semibold transition-colors">
        Create Account
      </a>
    </div>
    
    <div class="mt-6 text-center">
      <a href="/" class="text-indigo-600 hover:text-indigo-800 text-sm">← Back to Home</a>
    </div>
  </div>
</body>
</html>
