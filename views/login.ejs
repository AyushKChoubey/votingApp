<!DOCTYPE html>
<html lang="en">
<head>
  <!-- Previous: <link href="/css/output.css" rel="stylesheet"> -->
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login - Voting App</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/css/animations.css">
</head>
<body class="min-h-screen bg-gradient-to-tr from-indigo-500 via-pink-400 to-yellow-300 flex items-center justify-center text-gray-900">
  <div class="w-full max-w-xl p-12 bg-white/80 rounded-3xl shadow-2xl animate-fade-in">
    <h2 class="text-3xl font-extrabold text-indigo-700 mb-6 text-center drop-shadow-lg">Login</h2>
    <form method="POST" action="/user/login" class="space-y-4">
      <input type="text" name="aadharCardNumber" placeholder="Aadhar Card Number" class="w-full px-4 py-2 border rounded focus:outline-none focus:ring-4 focus:ring-indigo-400 bg-white/90 text-gray-900 transition-all duration-200" required>
      <input type="password" name="password" placeholder="Password" class="w-full px-4 py-2 border rounded focus:outline-none focus:ring-4 focus:ring-pink-400 bg-white/90 text-gray-900 transition-all duration-200" required>
      <button type="submit" class="w-full py-2 bg-pink-600 text-white rounded-lg font-semibold shadow hover:bg-yellow-400 hover:text-indigo-700 focus:ring-4 focus:ring-pink-300 transition-all duration-300 animate-bounce-once">Login</button>
    </form>
    <p class="mt-6 text-center text-sm text-indigo-700">Don't have an account?
      <a href="/user/register" class="inline-block px-4 py-2 ml-2 bg-yellow-400 text-indigo-900 rounded hover:bg-yellow-500 font-semibold transition">Register</a>
    </p>
  </div>
</body>
</html>
