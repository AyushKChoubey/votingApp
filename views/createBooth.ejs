<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Booth - VoteHub</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .fade-in { animation: fadeIn 0.5s ease-out; }
    </style>
</head>
<body class="min-h-screen bg-gradient-to-br from-purple-900 via-blue-900 to-indigo-900">
    <!-- Navigation -->
    <nav class="bg-black/30 backdrop-blur-md border-b border-white/10">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16 items-center">
                <div class="flex items-center space-x-4">
                    <a href="/booth/dashboard" class="flex items-center space-x-2 text-white hover:text-purple-300 transition">
                        <i class="fas fa-arrow-left"></i>
                        <span>Back to Dashboard</span>
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="max-w-4xl mx-auto px-4 py-8">
        <div class="bg-white/10 backdrop-blur-md rounded-2xl p-8 border border-white/20 fade-in">
            <h2 class="text-3xl font-bold text-white mb-6">
                <i class="fas fa-plus-circle text-purple-400 mr-3"></i>Create New Booth
            </h2>

            <form id="createBoothForm" method="POST" action="/booth/create" class="space-y-6">
                <!-- Basic Information -->
                <div class="space-y-4">
                    <h3 class="text-xl font-semibold text-white/90">Basic Information</h3>
                    
                    <div>
                        <label for="name" class="block text-white/80 mb-2">Booth Name *</label>
                        <input type="text" id="name" name="name" required 
                               class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-lg text-white placeholder-white/40 focus:outline-none focus:border-purple-400 focus:bg-white/20 transition"
                               placeholder="e.g., Class President Election 2025">
                    </div>

                    <div>
                        <label for="description" class="block text-white/80 mb-2">Description *</label>
                        <textarea id="description" name="description" required rows="3"
                                  class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-lg text-white placeholder-white/40 focus:outline-none focus:border-purple-400 focus:bg-white/20 transition"
                                  placeholder="Describe what this voting booth is about..."></textarea>
                    </div>
                </div>

                <!-- Candidates -->
                <div class="space-y-4">
                    <h3 class="text-xl font-semibold text-white/90">Candidates</h3>
                    <p class="text-white/60 text-sm">Add at least 2 candidates for the booth</p>
                    
                    <div id="candidatesContainer" class="space-y-3">
                        <div class="candidate-input flex gap-3">
                            <input type="text" name="candidates[]" required
                                   class="flex-1 px-4 py-3 bg-white/10 border border-white/20 rounded-lg text-white placeholder-white/40 focus:outline-none focus:border-purple-400 focus:bg-white/20 transition"
                                   placeholder="Candidate name">
                            <button type="button" onclick="removeCandidate(this)" class="px-4 py-3 bg-red-500/30 text-red-300 rounded-lg hover:bg-red-500/50 transition opacity-0 pointer-events-none">
                                <i class="fas fa-trash"></i>
                            </button>
                        </div>
                        <div class="candidate-input flex gap-3">
                            <input type="text" name="candidates[]" required
                                   class="flex-1 px-4 py-3 bg-white/10 border border-white/20 rounded-lg text-white placeholder-white/40 focus:outline-none focus:border-purple-400 focus:bg-white/20 transition"
                                   placeholder="Candidate name">
                            <button type="button" onclick="removeCandidate(this)" class="px-4 py-3 bg-red-500/30 text-red-300 rounded-lg hover:bg-red-500/50 transition opacity-0 pointer-events-none">
                                <i class="fas fa-trash"></i>
                            </button>
                        </div>
                    </div>
                    
                    <button type="button" onclick="addCandidate()" class="px-4 py-2 bg-purple-600/30 text-purple-300 rounded-lg hover:bg-purple-600/50 transition">
                        <i class="fas fa-plus mr-2"></i>Add Candidate
                    </button>
                </div>

                <!-- Settings -->
                <div class="space-y-4">
                    <h3 class="text-xl font-semibold text-white/90">Settings</h3>
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label for="maxMembers" class="block text-white/80 mb-2">Maximum Members</label>
                            <input type="number" id="maxMembers" name="maxMembers" min="2" value="100"
                                   class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-lg text-white placeholder-white/40 focus:outline-none focus:border-purple-400 focus:bg-white/20 transition">
                        </div>

                        <div>
                            <label for="emailDomain" class="block text-white/80 mb-2">Email Domain Restriction (Optional)</label>
                            <input type="text" id="emailDomain" name="settings[emailDomainRestriction]"
                                   class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-lg text-white placeholder-white/40 focus:outline-none focus:border-purple-400 focus:bg-white/20 transition"
                                   placeholder="e.g., company.com">
                        </div>
                    </div>

                    <div class="space-y-3">
                        <label class="flex items-center space-x-3 text-white/80 cursor-pointer">
                            <input type="checkbox" name="settings[resultsVisibleToVoters]" checked
                                   class="w-5 h-5 bg-white/10 border-white/20 rounded focus:ring-purple-400">
                            <span>Allow voters to see results</span>
                        </label>

                        <label class="flex items-center space-x-3 text-white/80 cursor-pointer">
                            <input type="checkbox" name="settings[requireApproval]"
                                   class="w-5 h-5 bg-white/10 border-white/20 rounded focus:ring-purple-400">
                            <span>Require approval to join booth</span>
                        </label>
                    </div>

                    <div>
                        <label for="votingEndsAt" class="block text-white/80 mb-2">Voting End Date (Optional)</label>
                        <input type="datetime-local" id="votingEndsAt" name="settings[votingEndsAt]"
                               class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-lg text-white placeholder-white/40 focus:outline-none focus:border-purple-400 focus:bg-white/20 transition">
                    </div>
                </div>

                <!-- Submit Button -->
                <div class="flex justify-end space-x-4 pt-6 border-t border-white/10">
                    <a href="/booth/dashboard" class="px-6 py-3 bg-white/10 text-white rounded-lg hover:bg-white/20 transition">
                        Cancel
                    </a>
                    <button type="submit" class="px-6 py-3 bg-purple-600 text-white rounded-lg hover:bg-purple-700 transition">
                        <i class="fas fa-check mr-2"></i>Create Booth
                    </button>
                </div>
            </form>
        </div>
    </div>

    <script>
        function addCandidate() {
            const container = document.getElementById('candidatesContainer');
            const div = document.createElement('div');
            div.className = 'candidate-input flex gap-3 fade-in';
            div.innerHTML = `
                <input type="text" name="candidates[]" required
                       class="flex-1 px-4 py-3 bg-white/10 border border-white/20 rounded-lg text-white placeholder-white/40 focus:outline-none focus:border-purple-400 focus:bg-white/20 transition"
                       placeholder="Candidate name">
                <button type="button" onclick="removeCandidate(this)" class="px-4 py-3 bg-red-500/30 text-red-300 rounded-lg hover:bg-red-500/50 transition">
                    <i class="fas fa-trash"></i>
                </button>
            `;
            container.appendChild(div);
            updateRemoveButtons();
        }

        function removeCandidate(button) {
            button.closest('.candidate-input').remove();
            updateRemoveButtons();
        }

        function updateRemoveButtons() {
            const inputs = document.querySelectorAll('.candidate-input');
            inputs.forEach((input, index) => {
                const removeBtn = input.querySelector('button');
                if (inputs.length > 2) {
                    removeBtn.classList.remove('opacity-0', 'pointer-events-none');
                } else {
                    removeBtn.classList.add('opacity-0', 'pointer-events-none');
                }
            });
        }

        // Handle form submission
        document.getElementById('createBoothForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const formData = new FormData(e.target);
            const candidates = formData.getAll('candidates[]').filter(c => c.trim());
            
            if (candidates.length < 2) {
                alert('Please add at least 2 candidates');
                return;
            }

            const data = {
                name: formData.get('name'),
                description: formData.get('description'),
                candidates: candidates,
                maxMembers: formData.get('maxMembers') || 100,
                settings: {
                    emailDomainRestriction: formData.get('settings[emailDomainRestriction]') || '',
                    resultsVisibleToVoters: formData.get('settings[resultsVisibleToVoters]') === 'on',
                    requireApproval: formData.get('settings[requireApproval]') === 'on',
                    votingEndsAt: formData.get('settings[votingEndsAt]') || ''
                }
            };

            try {
                const response = await fetch('/booth/create', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Accept': 'application/json'
                    },
                    body: JSON.stringify(data)
                });
                if (response.ok) {
                    window.location.href = '/booth/dashboard';
                } else {
                    const res = await response.json().catch(() => ({}));
                    alert(res.message || 'Failed to create booth. Please try again.');
                }
            } catch (err) {
                alert('An error occurred. Please try again.');
            }
        });
    </script>
</body>
</html>