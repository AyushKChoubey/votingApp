<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="/public/css/tailwind.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
</head>
<body class="bg-gradient-to-br from-blue-50 to-indigo-100 min-h-screen">
    <!-- Navigation -->
    <nav class="bg-white shadow-lg fixed w-full z-50 top-0">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16">
                <div class="flex items-center">
                    <div class="flex-shrink-0 flex items-center">
                        <i class="fas fa-vote-yea text-3xl text-primary mr-2"></i>
                        <span class="font-bold text-2xl text-gray-800">VoteBooth</span>
                    </div>
                </div>
                <div class="hidden md:flex items-center space-x-4">
                    <a href="/about" class="text-gray-700 hover:text-primary px-3 py-2 rounded-md text-sm font-medium transition-colors">About</a>
                    <a href="/features" class="text-gray-700 hover:text-primary px-3 py-2 rounded-md text-sm font-medium transition-colors">Features</a>
                    <a href="/pricing" class="text-gray-700 hover:text-primary px-3 py-2 rounded-md text-sm font-medium transition-colors">Pricing</a>
                    <a href="/contact" class="text-gray-700 hover:text-primary px-3 py-2 rounded-md text-sm font-medium transition-colors">Contact</a>
                    <% if (user) { %>
                        <a href="/booth/dashboard" class="bg-primary text-white px-4 py-2 rounded-md text-sm font-medium hover:bg-blue-700 transition-colors">Dashboard</a>
                        <a href="/user/logout" class="text-gray-700 hover:text-red-600 px-3 py-2 rounded-md text-sm font-medium transition-colors">Logout</a>
                    <% } else { %>
                        <a href="/user/login" class="text-primary hover:text-blue-700 px-3 py-2 rounded-md text-sm font-medium transition-colors">Login</a>
                        <a href="/user/register" class="bg-primary text-white px-4 py-2 rounded-md text-sm font-medium hover:bg-blue-700 transition-colors">Sign Up</a>
                    <% } %>
                </div>
            </div>
        </div>
    </nav>

    <!-- Alert Messages -->
    <% if (alertMessage) { %>
        <div class="fixed top-20 left-1/2 transform -translate-x-1/2 z-40 w-full max-w-md">
            <div class="alert-<%= alertType %> px-6 py-4 rounded-lg shadow-lg mx-4 
                     <%= alertType === 'success' ? 'bg-green-100 border border-green-400 text-green-700' : 
                         alertType === 'warning' ? 'bg-yellow-100 border border-yellow-400 text-yellow-700' : 
                         'bg-blue-100 border border-blue-400 text-blue-700' %>">
                <div class="flex items-center">
                    <i class="fas fa-<%= alertType === 'success' ? 'check-circle' : alertType === 'warning' ? 'exclamation-triangle' : 'info-circle' %> mr-2"></i>
                    <%= alertMessage %>
                </div>
            </div>
        </div>
    <% } %>

    <!-- Hero Section -->
    <section class="pt-20 pb-16 overflow-hidden">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
            <div class="lg:grid lg:grid-cols-12 lg:gap-8">
                <div class="sm:text-center md:max-w-2xl md:mx-auto lg:col-span-6 lg:text-left">
                    <h1 class="text-4xl font-bold text-gray-900 sm:text-5xl md:text-6xl">
                        <span class="block">Secure Online</span>
                        <span class="block text-primary">Voting Platform</span>
                    </h1>
                    <p class="mt-3 text-base text-gray-500 sm:mt-5 sm:text-xl lg:text-lg xl:text-xl">
                        Create, manage, and participate in secure voting booths with advanced security features. 
                        From small team decisions to large-scale elections, VoteBooth has you covered.
                    </p>
                    <div class="mt-8 sm:max-w-lg sm:mx-auto sm:text-center lg:text-left lg:mx-0">
                        <% if (!user) { %>
                            <a href="/user/register" class="inline-flex items-center px-8 py-4 border border-transparent text-lg font-medium rounded-md text-white bg-primary hover:bg-blue-700 transform hover:scale-105 transition-all duration-200 shadow-lg">
                                <i class="fas fa-rocket mr-2"></i>
                                Get Started Free
                            </a>
                            <a href="/features" class="ml-4 inline-flex items-center px-6 py-4 border border-gray-300 text-lg font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 transition-colors">
                                <i class="fas fa-play mr-2"></i>
                                Learn More
                            </a>
                        <% } else { %>
                            <a href="/booth/create" class="inline-flex items-center px-8 py-4 border border-transparent text-lg font-medium rounded-md text-white bg-primary hover:bg-blue-700 transform hover:scale-105 transition-all duration-200 shadow-lg">
                                <i class="fas fa-plus mr-2"></i>
                                Create New Booth
                            </a>
                            <a href="/booth/dashboard" class="ml-4 inline-flex items-center px-6 py-4 border border-gray-300 text-lg font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 transition-colors">
                                <i class="fas fa-tachometer-alt mr-2"></i>
                                Dashboard
                            </a>
                        <% } %>
                    </div>
                </div>
                <div class="mt-12 relative sm:max-w-lg sm:mx-auto lg:mt-0 lg:max-w-none lg:mx-0 lg:col-span-6 lg:flex lg:items-center">
                    <div class="relative mx-auto w-full rounded-lg shadow-lg lg:max-w-md">
                        <div class="bg-white rounded-lg shadow-2xl overflow-hidden">
                            <div class="px-6 py-8">
                                <div class="flex items-center justify-center w-16 h-16 bg-primary rounded-full mx-auto mb-4">
                                    <i class="fas fa-shield-alt text-white text-2xl"></i>
                                </div>
                                <h3 class="text-lg font-semibold text-center text-gray-900 mb-4">Secure & Transparent</h3>
                                <div class="space-y-3">
                                    <div class="flex items-center text-sm text-gray-600">
                                        <i class="fas fa-check text-green-500 mr-2"></i>
                                        End-to-end encryption
                                    </div>
                                    <div class="flex items-center text-sm text-gray-600">
                                        <i class="fas fa-check text-green-500 mr-2"></i>
                                        Real-time results
                                    </div>
                                    <div class="flex items-center text-sm text-gray-600">
                                        <i class="fas fa-check text-green-500 mr-2"></i>
                                        Audit trail
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Features Preview -->
    <section class="py-16 bg-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center">
                <h2 class="text-3xl font-bold text-gray-900 sm:text-4xl">
                    Why Choose VoteBooth?
                </h2>
                <p class="mt-4 max-w-2xl mx-auto text-xl text-gray-500">
                    Built with security, transparency, and user experience in mind
                </p>
            </div>

            <div class="mt-16 grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
                <div class="text-center group hover:transform hover:scale-105 transition-all duration-300">
                    <div class="flex items-center justify-center w-16 h-16 bg-blue-100 rounded-full mx-auto group-hover:bg-primary group-hover:text-white transition-colors">
                        <i class="fas fa-lock text-2xl text-primary group-hover:text-white"></i>
                    </div>
                    <h3 class="mt-6 text-lg font-semibold text-gray-900">Secure by Design</h3>
                    <p class="mt-2 text-gray-600">Advanced security features with JWT authentication and rate limiting</p>
                </div>

                <div class="text-center group hover:transform hover:scale-105 transition-all duration-300">
                    <div class="flex items-center justify-center w-16 h-16 bg-green-100 rounded-full mx-auto group-hover:bg-primary group-hover:text-white transition-colors">
                        <i class="fas fa-users text-2xl text-green-600 group-hover:text-white"></i>
                    </div>
                    <h3 class="mt-6 text-lg font-semibold text-gray-900">Easy Management</h3>
                    <p class="mt-2 text-gray-600">Intuitive booth creation and member management tools</p>
                </div>

                <div class="text-center group hover:transform hover:scale-105 transition-all duration-300">
                    <div class="flex items-center justify-center w-16 h-16 bg-purple-100 rounded-full mx-auto group-hover:bg-primary group-hover:text-white transition-colors">
                        <i class="fas fa-chart-bar text-2xl text-purple-600 group-hover:text-white"></i>
                    </div>
                    <h3 class="mt-6 text-lg font-semibold text-gray-900">Real-time Results</h3>
                    <p class="mt-2 text-gray-600">Live vote counting and comprehensive analytics</p>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <section class="bg-primary">
        <div class="max-w-7xl mx-auto py-12 px-4 sm:px-6 lg:py-16 lg:px-8 lg:flex lg:items-center lg:justify-between">
            <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">
                <span class="block">Ready to start voting?</span>
                <span class="block text-blue-200">Join thousands of satisfied users.</span>
            </h2>
            <div class="mt-8 flex lg:mt-0 lg:flex-shrink-0">
                <div class="inline-flex rounded-md shadow">
                    <% if (!user) { %>
                        <a href="/user/register" class="inline-flex items-center justify-center px-8 py-3 border border-transparent text-base font-medium rounded-md text-primary bg-white hover:bg-gray-50 transform hover:scale-105 transition-all">
                            Get Started
                        </a>
                    <% } else { %>
                        <a href="/booth/create" class="inline-flex items-center justify-center px-8 py-3 border border-transparent text-base font-medium rounded-md text-primary bg-white hover:bg-gray-50 transform hover:scale-105 transition-all">
                            Create Booth
                        </a>
                    <% } %>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="bg-gray-800">
        <div class="max-w-7xl mx-auto py-12 px-4 sm:px-6 lg:px-8">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
                <div class="col-span-1 md:col-span-2">
                    <div class="flex items-center mb-4">
                        <i class="fas fa-vote-yea text-3xl text-primary mr-2"></i>
                        <span class="font-bold text-2xl text-white">VoteBooth</span>
                    </div>
                    <p class="text-gray-300 max-w-md">
                        Secure, transparent, and user-friendly online voting platform for all your decision-making needs.
                    </p>
                </div>
                <div>
                    <h3 class="text-sm font-semibold text-gray-400 tracking-wider uppercase mb-4">Company</h3>
                    <ul class="space-y-2">
                        <li><a href="/about" class="text-gray-300 hover:text-white transition-colors">About</a></li>
                        <li><a href="/features" class="text-gray-300 hover:text-white transition-colors">Features</a></li>
                        <li><a href="/pricing" class="text-gray-300 hover:text-white transition-colors">Pricing</a></li>
                        <li><a href="/contact" class="text-gray-300 hover:text-white transition-colors">Contact</a></li>
                    </ul>
                </div>
                <div>
                    <h3 class="text-sm font-semibold text-gray-400 tracking-wider uppercase mb-4">Legal</h3>
                    <ul class="space-y-2">
                        <li><a href="/privacy" class="text-gray-300 hover:text-white transition-colors">Privacy Policy</a></li>
                        <li><a href="/terms" class="text-gray-300 hover:text-white transition-colors">Terms of Service</a></li>
                        <li><a href="/help" class="text-gray-300 hover:text-white transition-colors">Help & FAQ</a></li>
                    </ul>
                </div>
            </div>
            <div class="mt-8 pt-8 border-t border-gray-700">
                <p class="text-center text-gray-400">&copy; 2025 VoteBooth. All rights reserved.</p>
            </div>
        </div>
    </footer>

    <script>
        // Auto-hide alerts after 5 seconds
        setTimeout(() => {
            const alerts = document.querySelectorAll('[class*="alert-"]');
            alerts.forEach(alert => {
                alert.style.opacity = '0';
                alert.style.transform = 'translateY(-100%)';
                setTimeout(() => alert.remove(), 300);
            });
        }, 5000);
    </script>
</body>
</html>