<!DOCTYPE html>
<html lang="en">
<head>
  <!-- Previous: <link href="/css/output.css" rel="stylesheet"> -->
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Voting App</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/css/animations.css">
</head>
<body class="min-h-screen bg-gradient-to-tr from-indigo-500 via-pink-400 to-yellow-300 flex items-center justify-center text-gray-900">
  <div class="w-full h-full flex flex-col items-center justify-center">
  <div class="w-full max-w-2xl mx-auto p-10 rounded-3xl shadow-2xl bg-white/80 backdrop-blur-lg text-center mt-10 mb-6 animate-fade-in">
      <h1 class="text-5xl font-extrabold text-indigo-700 mb-4 drop-shadow-lg">Voting App</h1>
      <p class="text-lg text-gray-700 mb-8">Empowering secure, fair, and easy online voting for everyone.<br>Sign up, vote, and see results instantly!</p>
      <div class="flex flex-col md:flex-row gap-6 justify-center mb-4">
  <a href="/user/login" class="px-8 py-3 rounded-xl bg-indigo-600 text-white font-bold shadow hover:bg-yellow-400 hover:text-indigo-700 focus:ring-4 focus:ring-indigo-300 transition-all duration-300 animate-bounce-once">Login</a>
  <a href="/user/register" class="px-8 py-3 rounded-xl bg-pink-500 text-white font-bold shadow hover:bg-yellow-400 hover:text-indigo-700 focus:ring-4 focus:ring-pink-300 transition-all duration-300 animate-bounce-once">Register</a>
  <a href="/candidate" class="px-8 py-3 rounded-xl bg-yellow-400 text-indigo-900 font-bold shadow hover:bg-pink-500 hover:text-white focus:ring-4 focus:ring-yellow-300 transition-all duration-300 animate-bounce-once">View Candidates</a>
  <a href="/candidate/vote/count" class="px-8 py-3 rounded-xl bg-green-500 text-white font-bold shadow hover:bg-yellow-400 hover:text-indigo-700 focus:ring-4 focus:ring-green-300 transition-all duration-300 animate-bounce-once">View Results</a>
      </div>
    </div>
    <footer class="w-full text-gray-700 text-sm text-center mb-4">
      &copy; <%= new Date().getFullYear() %> Voting App. All rights reserved.
    </footer>
  </div>
</body>
</html>
